---
import Footer from '../components/Footer.astro';
import SearchPalette from '../components/SearchPalette.tsx';
import type { SearchItem } from '../components/SearchPalette.tsx';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  game: string;
  breadcrumbs: BreadcrumbItem[];
  ogImage?: string;
}

const {
  title,
  description,
  game,
  breadcrumbs,
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

const fullBreadcrumbs: BreadcrumbItem[] = [
  { label: 'codigosgratis.com', href: '/' },
  { label: 'Games', href: '/games/' },
  { label: game, href: `/games/${game.toLowerCase()}/` },
  ...breadcrumbs,
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: fullBreadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.label,
    item: new URL(crumb.href, Astro.site).href,
  })),
};

const gameSlug = game.toLowerCase();
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (currentPath === href) return true;
  if (href.startsWith('/games/') && href !== `/games/${gameSlug}/`) {
    return currentPath.startsWith(href);
  }
  return false;
}

// --- Game navigation tabs (game.guide style) ---
const gameTabs = [
  { label: 'Value List', href: `/games/${gameSlug}/values/` },
  { label: 'Calculator', href: `/games/${gameSlug}/calculator/` },
  { label: 'Trading Hub', href: `/games/${gameSlug}/trading/` },
  { label: 'Boat Tier List', href: `/games/${gameSlug}/boats/tier-list/` },
  { label: 'Rod Skins Tier List', href: `/games/${gameSlug}/rod-skins/tier-list/` },
  { label: 'Fish', href: `/games/${gameSlug}/fish/` },
  { label: 'Map', href: `/games/${gameSlug}/map/` },
  { label: 'Codes', href: `/codigos-${gameSlug}/` },
];

// "More" items — secondary pages not in the main tabs
const moreNavItems = [
  { label: 'Boats', href: `/games/${gameSlug}/boats/` },
  { label: 'Rod Skins', href: `/games/${gameSlug}/rod-skins/` },
  { label: 'Rods', href: `/games/${gameSlug}/rods/` },
  { label: 'Enchantments', href: `/games/${gameSlug}/enchantments/` },
  { label: 'Baits', href: `/games/${gameSlug}/baits/` },
  { label: 'Bobbers', href: `/games/${gameSlug}/bobbers/` },
  { label: 'Mutations', href: `/games/${gameSlug}/mutations/` },
  { label: 'Locations', href: `/games/${gameSlug}/locations/` },
];

// SVG icon inner content (24x24 viewBox, stroke-based)
const ico: Record<string, string> = {
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  chevron: '<path d="m9 18 6-6-6-6"/>',
  x: '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>',
  more: '<circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>',
  down: '<path d="m6 9 6 6 6-6"/>',
};

// --- Search palette data (Fisch only) ---
let searchItems: SearchItem[] = [];
if (gameSlug === 'fisch') {
  const fishData = (await import('../data/games/fisch/fish.json')).default as any[];
  const mutData = (await import('../data/games/fisch/mutations.json')).default as any[];
  const rodData = (await import('../data/games/fisch/rods.json')).default as any[];
  const locData = (await import('../data/games/fisch/locations.json')).default as any[];
  const rodSkinsData = (await import('../data/games/fisch/rod-skins.json')).default as any[];
  const boatsData = (await import('../data/games/fisch/boats.json')).default as any[];
  const enchData = (await import('../data/games/fisch/enchantments.json')).default as any[];
  const baitData = (await import('../data/games/fisch/baits.json')).default as any[];
  const bobberData = (await import('../data/games/fisch/bobbers.json')).default as any[];
  searchItems = [
    ...fishData.filter((f: any) => f.id && f.name).map((f: any) => ({ i: f.id, n: f.name, t: 'f' as const, x: f.rarity || undefined })),
    ...mutData.filter((m: any) => m.id && m.name).map((m: any) => ({ i: m.id, n: m.name, t: 'm' as const, x: m.category || undefined })),
    ...rodData.filter((r: any) => r.id && r.name).map((r: any) => ({ i: r.id, n: r.name, t: 'r' as const })),
    ...locData.filter((l: any) => l.id && l.name).map((l: any) => ({ i: l.id, n: l.name, t: 'l' as const })),
    ...rodSkinsData.filter((s: any) => s.slug && s.name).map((s: any) => ({ i: s.slug, n: s.name, t: 's' as const, x: s.rarity || undefined })),
    ...boatsData.filter((b: any) => b.slug && b.name).map((b: any) => ({ i: b.slug, n: b.name, t: 'b' as const, x: b.rarity || undefined })),
    ...enchData.filter((e: any) => e.slug && e.name).map((e: any) => ({ i: e.slug, n: e.name, t: 'e' as const, x: e.type || undefined })),
    ...baitData.filter((a: any) => a.slug && a.name).map((a: any) => ({ i: a.slug, n: a.name, t: 'a' as const, x: a.rarity || undefined })),
    ...bobberData.filter((o: any) => o.slug && o.name).map((o: any) => ({ i: o.slug, n: o.name, t: 'o' as const, x: o.category || undefined })),
  ];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Codigos Gratis" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5467700828296629"
     crossorigin="anonymous"></script>
  </head>
  <body>
    <!-- TOPBAR -->
    <header class="topbar">
      <div class="topbar__inner">
        <a href="/" class="topbar__home" title="codigosgratis.com">
          <span class="topbar__home-logo">CG</span>
        </a>
        <span class="topbar__sep" aria-hidden="true"></span>
        <a href={`/games/${gameSlug}/`} class="topbar__brand">
          <img src="/images/fisch-icon.webp" alt="" class="topbar__brand-icon" width="24" height="24" />
          <span class="topbar__brand-name">{game}</span>
          <span class="topbar__brand-badge">Guide</span>
        </a>

        <button class="topbar__search" type="button" id="searchTrigger">
          <svg class="topbar__search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ico.search} />
          <span class="topbar__search-text">Search...</span>
          <kbd class="topbar__search-kbd">Ctrl K</kbd>
        </button>
      </div>
    </header>

    <!-- GAME NAV (horizontal tabs — game.guide style) -->
    <nav class="gnav" aria-label="Game navigation">
      <div class="gnav__inner">
        <div class="gnav__tabs">
          {gameTabs.map(tab => (
            <a
              href={tab.href}
              class:list={['gnav__tab', { active: isActive(tab.href) }]}
            >
              {tab.label}
            </a>
          ))}
          <div class="gnav__more" id="gnavMore">
            <button class="gnav__tab gnav__more-btn" type="button" id="gnavMoreBtn">
              More
              <svg class="gnav__more-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={ico.down} />
            </button>
            <div class="gnav__dropdown" id="gnavDropdown">
              {moreNavItems.map(item => (
                <a
                  href={item.href}
                  class:list={['gnav__dropdown-link', { active: isActive(item.href) }]}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="page-wrap">
      <nav class="bc" aria-label="Breadcrumb">
        <ol class="bc__list">
          {fullBreadcrumbs.map((crumb, i) => (
            <li class="bc__item">
              {i < fullBreadcrumbs.length - 1 ? (
                <>
                  <a href={crumb.href} class="bc__link">{crumb.label}</a>
                  <svg class="bc__sep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ico.chevron} />
                </>
              ) : (
                <span class="bc__current" aria-current="page">{crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>

      <main class="content">
        <slot />
      </main>

      <Footer />
    </div>

    <!-- Interactions -->
    <script is:inline>
      (function(){
        // "More" dropdown
        var moreBtn=document.getElementById('gnavMoreBtn');
        var moreWrap=document.getElementById('gnavMore');
        if(moreBtn&&moreWrap){
          moreBtn.onclick=function(e){
            e.stopPropagation();
            moreWrap.classList.toggle('open');
          };
          document.addEventListener('click',function(){moreWrap.classList.remove('open')});
        }
      })();
    </script>

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>

    {/* Search palette trigger script */}
    <script>
      document.getElementById('searchTrigger')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-search'));
      });
    </script>

    {/* Search palette */}
    {gameSlug === 'fisch' && searchItems.length > 0 && (
      <SearchPalette client:idle items={searchItems} gameSlug={gameSlug} />
    )}
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg-deep: #060B18;
    --bg-card: #0F1D35;
    --bg-elevated: #142847;
    --bg-code: #0A1628;
    --accent: #1DA2D8;
    --accent-secondary: #22D3EE;
    --accent-hot: #F97316;
    --accent-warn: #EAB308;
    --accent-success: #22C55E;
    --text: #E2E8F0;
    --text-dim: #94A3B8;
    --border: rgba(255, 255, 255, 0.08);
    --font-body: 'Inter', system-ui, sans-serif;
    --font-display: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --topbar-h: 56px;
    --gnav-h: 44px;
    --radius: 8px;
    --radius-sm: 6px;
    --radius-pill: 9999px;
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    overflow-x: hidden;
    font-family: var(--font-body);
    font-weight: 400;
    background: var(--bg-deep);
    color: var(--text);
    line-height: 1.6;
    min-height: 100dvh;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }
  }
</style>

<style>
  /* ==========================================================================
     TOPBAR
     ========================================================================== */

  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--topbar-h);
    background: rgba(6, 11, 24, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .topbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
  }

  .topbar__home {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .topbar__home-logo {
    font-weight: 800;
    font-size: 0.85rem;
    color: var(--accent);
    background: rgba(29, 162, 216, 0.12);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    letter-spacing: 0.5px;
    transition: background 0.2s;
  }

  .topbar__home:hover .topbar__home-logo {
    background: rgba(29, 162, 216, 0.22);
  }

  .topbar__sep {
    width: 1px;
    height: 20px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0 0.15rem;
  }

  .topbar__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .topbar__brand-icon {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .topbar__brand-name {
    font-weight: 700;
    font-size: 1.125rem;
    color: #fff;
  }

  .topbar__brand-badge {
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(29, 162, 216, 0.12);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .topbar__search {
    -webkit-appearance: none;
    appearance: none;
    outline: none;
    flex: 1;
    max-width: 360px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.4rem 0.75rem;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.4;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .topbar__search:hover {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.08);
  }

  .topbar__search-ico {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--text-dim);
  }

  .topbar__search-text {
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .topbar__search-kbd {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    line-height: 1.4;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 639px) {
    .topbar__home-logo {
      font-size: 0.75rem;
      padding: 0.15rem 0.4rem;
    }
    .topbar__sep {
      height: 16px;
    }
    .topbar__search {
      max-width: none;
      flex: 0 0 auto;
      padding: 0.4rem 0.55rem;
      border-radius: var(--radius-sm);
    }
    .topbar__search-text,
    .topbar__search-kbd {
      display: none;
    }
  }

  /* ==========================================================================
     GAME NAV (horizontal tabs — game.guide style)
     ========================================================================== */

  .gnav {
    position: sticky;
    top: var(--topbar-h);
    z-index: 90;
    background: rgba(6, 11, 24, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .gnav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .gnav__tabs {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .gnav__tabs::-webkit-scrollbar {
    display: none;
  }

  .gnav__tab {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.7rem 0.85rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-dim);
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    cursor: pointer;
    font-family: var(--font-body);
  }

  .gnav__tab:hover {
    color: var(--text);
  }

  .gnav__tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 639px) {
    .gnav__tab {
      padding: 0.6rem 0.65rem;
      font-size: 0.78rem;
    }
  }

  /* "More" dropdown */
  .gnav__more {
    position: relative;
    flex-shrink: 0;
  }

  .gnav__more-btn {
    border-bottom: 2px solid transparent !important;
  }

  .gnav__more-chevron {
    width: 14px;
    height: 14px;
    transition: transform 0.2s;
  }

  .gnav__more.open .gnav__more-chevron {
    transform: rotate(180deg);
  }

  .gnav__dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 1px);
    right: 0;
    min-width: 180px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    padding: 0.35rem;
    z-index: 100;
  }

  .gnav__more.open .gnav__dropdown {
    display: block;
  }

  .gnav__dropdown-link {
    display: block;
    padding: 0.55rem 0.85rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-dim);
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .gnav__dropdown-link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  .gnav__dropdown-link.active {
    color: var(--accent);
    background: rgba(29, 162, 216, 0.1);
  }

  /* ==========================================================================
     PAGE WRAP
     ========================================================================== */

  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100dvh - var(--topbar-h) - var(--gnav-h));
    display: flex;
    flex-direction: column;
  }

  /* ==========================================================================
     BREADCRUMBS
     ========================================================================== */

  .bc {
    padding: 0.75rem 1rem 0;
  }

  @media (min-width: 768px) {
    .bc {
      padding: 1rem 1.5rem 0;
    }
  }

  .bc__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    list-style: none;
  }

  .bc__item {
    display: flex;
    align-items: center;
    font-size: 0.8rem;
  }

  .bc__link {
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .bc__link:hover {
    color: var(--accent);
  }

  .bc__sep {
    width: 12px;
    height: 12px;
    margin: 0 0.25rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  .bc__current {
    color: var(--text);
    font-weight: 500;
  }

  /* ==========================================================================
     CONTENT
     ========================================================================== */

  .content {
    flex: 1;
    padding: 1rem 0 2rem;
  }

  @media (min-width: 768px) {
    .content {
      padding: 1.25rem 0 3rem;
    }
  }

  /* ==========================================================================
     SEARCH PALETTE (React component global styles)
     ========================================================================== */

  :global(.sp__overlay) {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: min(20vh, 120px);
  }

  :global(.sp__modal) {
    width: 100%;
    max-width: 560px;
    margin: 0 1rem;
    background: var(--bg-card, #0F1D35);
    border: 1px solid var(--border, #1e293b);
    border-radius: 16px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  :global(.sp__input-wrap) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border, #1e293b);
  }

  :global(.sp__input-ico) {
    flex-shrink: 0;
    color: var(--text-dim, #64748b);
  }

  :global(.sp__input) {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text, #e8eaf0);
    font-family: var(--font-body, system-ui);
    font-size: 1rem;
    line-height: 1.5;
  }

  :global(.sp__input::placeholder) {
    color: var(--text-dim, #64748b);
  }

  :global(.sp__kbd) {
    font-family: var(--font-body, system-ui);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-dim, #64748b);
    background: rgba(255, 255, 255, 0.06);
