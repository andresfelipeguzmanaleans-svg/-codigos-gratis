---
export const prerender = true;
import GameLayout from '../../../layouts/GameLayout.astro';
import GameHero from '../../../components/GameHero.astro';

import valuesData from '../../../data/games/blox-fruits/values.json';

const items = (valuesData as any).items || valuesData;
const total = items.length;
const fruitsCount = items.filter((i: any) => i.category === 'Fruits').length;
const limitedsCount = items.filter((i: any) => i.category === 'Limiteds').length;
const gamepassCount = items.filter((i: any) => i.category === 'Gamepasses').length;

const fmt = (n: number) => n.toLocaleString('en-US');

const description = `Complete Blox Fruits value list with ${fmt(total)} items, trade calculator, and active codes. Check fruit values, permanent prices, demand, and trends. Updated daily.`;

const quickLinks = [
  { title: 'Value List', desc: `${fmt(total)} items with trade values`, href: '/games/blox-fruits/values/', icon: 'chart' },
  { title: 'Trade Calculator', desc: 'Check if your trade is fair', href: '/games/blox-fruits/calculator/', icon: 'calc' },
  { title: 'Active Codes', desc: 'Free rewards & boosts', href: '/codigos-blox-fruits/', icon: 'gift' },
];

const stats = [
  { label: 'Total Items', value: fmt(total) },
  { label: 'Fruits', value: fmt(fruitsCount) },
  { label: 'Limiteds', value: fmt(limitedsCount) },
  { label: 'Gamepasses', value: fmt(gamepassCount) },
];

const faqs = [
  {
    q: 'What is Blox Fruits?',
    a: `Blox Fruits is one of the most popular Roblox games where players eat fruits to gain powerful abilities, fight bosses, explore islands, and trade with other players. The game features ${fmt(fruitsCount)} fruits, ${fmt(limitedsCount)} limited items, and ${fmt(gamepassCount)} gamepasses.`,
  },
  {
    q: 'How does trading work in Blox Fruits?',
    a: 'You can trade fruits, gamepasses, and limited items with other players. Each item has a trade value and a demand level. Use our trade calculator to check if your trade is a profit, balanced, or overpay before accepting.',
  },
  {
    q: 'What is the difference between normal and permanent value?',
    a: 'Normal (trade) value reflects how much an item is worth in a regular trade. Permanent value is the worth of the permanent version of a fruit, which stays in your inventory forever. Permanent fruits are typically worth more than their normal counterparts.',
  },
  {
    q: 'How do I get rare fruits in Blox Fruits?',
    a: 'Rare fruits can spawn randomly under trees across the map, be obtained from the Blox Fruits Dealer for Beli or Robux, found in the Stock rotation, or traded with other players. Mythical fruits like Dragon and Leopard are the hardest to obtain naturally.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Blox Fruits Guide - Codigos Gratis',
  url: new URL('/games/blox-fruits/', Astro.site).href,
  description,
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title="Blox Fruits Value List & Trade Calculator"
  description={description}
  game="Blox Fruits"
  breadcrumbs={[]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <GameHero title="BLOX FRUITS" subtitle="Values, calculator & trading tools" accentColor="#a855f7" />

  <div class="container home-content">

    <!-- QUICK LINKS -->
    <section class="quick-links">
      {quickLinks.map(link => (
        <a href={link.href} class="ql-card">
          <span class="ql-card__icon">
            {link.icon === 'chart' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><polyline points="7 14 11 10 15 13 21 6"/></svg>
            )}
            {link.icon === 'calc' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
            )}
            {link.icon === 'gift' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 4.8 0 0 1 12 8a4.8 4.8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
            )}
          </span>
          <div class="ql-card__body">
            <h3 class="ql-card__title">{link.title}</h3>
            <p class="ql-card__desc">{link.desc}</p>
          </div>
          <svg class="ql-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ))}
    </section>

    <!-- STATS -->
    <section class="stats-section">
      <h2 class="section-title">Database</h2>
      <div class="stats-row">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__value">{s.value}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <p class="faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

  </div>
</GameLayout>

<style>
  .home-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
    padding-bottom: 2rem;
  }

  /* Quick links grid */
  .quick-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .quick-links { grid-template-columns: repeat(3, 1fr); }
  }

  .ql-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius, 12px);
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
    text-decoration: none;
  }

  .ql-card:hover {
    border-color: rgba(168, 85, 247, 0.35);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .ql-card__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.08);
    border-radius: var(--radius, 12px);
    color: #a855f7;
  }

  .ql-card__body { flex: 1; min-width: 0; }

  .ql-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
  }

  .ql-card__desc {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-top: 1px;
  }

  .ql-card__arrow {
    flex-shrink: 0;
    color: rgba(255,255,255,0.2);
    transition: color 0.2s, transform 0.2s;
  }

  .ql-card:hover .ql-card__arrow {
    color: #a855f7;
    transform: translateX(2px);
  }

  /* Section title */
  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Stats */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm, 8px);
    min-width: 72px;
    flex: 1;
  }

  .stat__value {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: #a855f7;
    line-height: 1.2;
  }

  .stat__label {
    font-size: 0.6rem;
    color: var(--text-dim);
    font-weight: 500;
    text-align: center;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius, 12px);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(168, 85, 247, 0.2);
  }

  .faq-q {
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: color 0.2s;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.1rem;
    color: var(--text-dim);
    flex-shrink: 0;
    font-weight: 300;
  }

  .faq-item[open] .faq-q::after {
    content: '\2212';
    color: #a855f7;
  }

  .faq-q:hover { color: #a855f7; }

  .faq-a {
    padding: 0 1rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
