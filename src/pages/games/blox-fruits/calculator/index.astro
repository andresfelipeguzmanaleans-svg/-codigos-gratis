---
export const prerender = true;
import GameLayout from '../../../../layouts/GameLayout.astro';
import GameHero from '../../../../components/GameHero.astro';
import SimpleCalc from '../../../../components/SimpleCalc.tsx';
import type { CalcItem } from '../../../../components/SimpleCalc.tsx';

import valuesRaw from '../../../../data/games/blox-fruits/values.json';

// ---------- Data ----------

const valuesData = ((valuesRaw as any).items || valuesRaw) as any[];

const items: CalcItem[] = valuesData
  .filter((i: any) => i.tradeValue > 0)
  .map((i: any) => ({
    id: i.slug,
    name: i.name,
    value: i.tradeValue,
    rarity: i.rarity || 'Common',
    category: i.category || 'Fruits',
    imageUrl: i.imageUrl ? i.imageUrl : null,
  }));

const categories = ['Fruits', 'Gamepasses', 'Limiteds'];

const rarityColors: Record<string, string> = {
  Common: '#6b7280', Uncommon: '#84cc16', Rare: '#3b82f6',
  Legendary: '#fbbf24', Mythical: '#a855f7', Limited: '#ef4444', Gamepass: '#22c55e',
};

const fmt = (n: number) => n.toLocaleString('en-US');
const totalItems = items.length;

// Schema.org
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Blox Fruits Trade Calculator',
  description: `Blox Fruits trade calculator for ${totalItems.toLocaleString()} items: fruits, gamepasses, and limiteds. Check if your trade is a profit, balanced, or overpay.`,
  url: new URL('/games/blox-fruits/calculator/', Astro.site).href,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title="Trade Calculator - Profit/Balanced/Overpay Checker | Blox Fruits Roblox"
  description={`Check if your Blox Fruits trade is fair. Calculator for ${fmt(totalItems)} items including fruits, gamepasses, and limiteds with current trade values.`}
  game="Blox Fruits"
  breadcrumbs={[{ label: 'Trade Calculator', href: '/games/blox-fruits/calculator/' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  </Fragment>

  <GameHero title="TRADE CALCULATOR" subtitle="Check if your trade is fair" accentColor="#a855f7" />

  <div class="container">
    <!-- HOW IT WORKS -->
    <section class="tc-explainer">
      <div class="tc-explainer__card">
        <h2 class="tc-explainer__title">HOW IT WORKS</h2>
        <div class="tc-explainer__items">
          <div class="tc-explainer__item">
            <span class="tc-explainer__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
            </span>
            <div>
              <strong>Add Items</strong>
              <span class="tc-explainer__desc">Pick items for each side of the trade</span>
            </div>
          </div>
          <div class="tc-explainer__item">
            <span class="tc-explainer__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><polyline points="7 14 11 10 15 13 21 6"/></svg>
            </span>
            <div>
              <strong>Compare Values</strong>
              <span class="tc-explainer__desc">Total trade value is calculated automatically</span>
            </div>
          </div>
        </div>
        <p class="tc-explainer__text">
          A trade is <strong class="tc-explainer__profit">PROFIT</strong> if you gain &gt;5%,
          <strong class="tc-explainer__balanced">BALANCED</strong> if within &plusmn;5%, or
          <strong class="tc-explainer__overpay">OVERPAY</strong> if you lose &gt;5%.
        </p>
      </div>
    </section>

    <!-- REACT ISLAND -->
    <section class="tc-section">
      <SimpleCalc
        client:load
        items={items}
        categories={categories}
        valueUnit=""
        rarityColors={rarityColors}
      />
    </section>

    <!-- RELATED LINKS -->
    <section class="calc-links">
      <h2 class="calc-links__title">Related Tools & Data</h2>
      <div class="calc-links__grid">
        <a href="/games/blox-fruits/values/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><polyline points="7 14 11 10 15 13 21 6"/></svg>
          </span>
          <strong>Value List</strong>
          <span class="calc-link-card__desc">All trade values and price trends</span>
        </a>
        <a href="/codigos-blox-fruits/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 4.8 0 0 1 12 8a4.8 4.8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
          </span>
          <strong>Active Codes</strong>
          <span class="calc-link-card__desc">Redeem codes for free rewards</span>
        </a>
        <a href="/games/blox-fruits/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <strong>Blox Fruits Hub</strong>
          <span class="calc-link-card__desc">Main game page with all tools</span>
        </a>
      </div>
    </section>
  </div>
</GameLayout>

<style>
  /* ============================================================
     EXPLAINER
     ============================================================ */

  .tc-explainer {
    padding-bottom: 1.5rem;
  }

  .tc-explainer__card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .tc-explainer__title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .tc-explainer__items {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .tc-explainer__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text);
  }

  .tc-explainer__item strong {
    display: block;
    font-size: 0.82rem;
    color: #fff;
  }

  .tc-explainer__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    color: #a855f7;
    flex-shrink: 0;
  }

  .tc-explainer__desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .tc-explainer__text {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .tc-explainer__profit { color: #00ffaa; }
  .tc-explainer__balanced { color: #fbbf24; }
  .tc-explainer__overpay { color: #ff4d4d; }

  .tc-section {
    padding-bottom: 2rem;
  }

  /* ============================================================
     REACT COMPONENT: SimpleCalc  (.tc2__*)
     Slot-based grid with full-screen modal picker
     ============================================================ */

  :global(.tc2) { max-width: 100%; }

  /* --- Action bar --- */
  :global(.tc2__actions) { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 1rem; }
  :global(.tc2__act-btn) { display: inline-flex; align-items: center; gap: 0.35rem; background: none; border: 1px solid var(--border); border-radius: 8px; padding: 0.5rem 0.85rem; color: var(--text); font-family: var(--font-body); font-size: 0.82rem; font-weight: 500; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
  :global(.tc2__act-btn:hover) { border-color: #a855f7; background: rgba(168,85,247,0.06); }
  :global(.tc2__act-btn--danger:hover) { border-color: #ff4d4d; background: rgba(255,77,77,0.06); color: #ff4d4d; }
  :global(.tc2__act-btn:disabled) { opacity: 0.5; cursor: not-allowed; }

  /* --- Exchange grid (3 cols desktop, 1 col mobile) --- */
  :global(.tc2__exchange) { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0.75rem; align-items: start; margin-bottom: 1.5rem; }
  @media (max-width: 767px) { :global(.tc2__exchange) { grid-template-columns: 1fr; } }

  /* --- Zone (one side) --- */
  :global(.tc2__zone) { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 0.85rem; transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), opacity 0.4s; }
  :global(.tc2__zone--swap-r) { transform: translateX(30px); opacity: 0.3; }
  :global(.tc2__zone--swap-l) { transform: translateX(-30px); opacity: 0.3; }

  :global(.tc2__zone-head) { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.65rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--border); }
  :global(.tc2__zone-label) { font-family: var(--font-display); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em; }
  :global(.tc2__zone-count) { font-size: 0.68rem; color: var(--text-dim); font-weight: 500; }

  /* --- 3x3 slot grid --- */
  :global(.tc2__slots) { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-bottom: 0.65rem; }

  :global(.tc2__slot) { position: relative; aspect-ratio: 1; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; }

  /* Empty slot */
  :global(.tc2__slot--empty) { border: 1px dashed rgba(255,255,255,0.1); background: linear-gradient(135deg, rgba(45,36,56,0.3), rgba(26,22,37,0.8)); cursor: pointer; transition: border-color 0.2s, background 0.2s; }
  :global(.tc2__slot--empty:hover) { border-color: #a855f7; background: linear-gradient(135deg, rgba(45,36,56,0.5), rgba(26,22,37,0.9)); }
  :global(.tc2__slot-plus) { color: rgba(255,255,255,0.25); transition: color 0.2s; }
  :global(.tc2__slot--empty:hover .tc2__slot-plus) { color: #a855f7; }

  /* Filled slot */
  :global(.tc2__slot--filled) { border: 1px solid rgba(255,255,255,0.08); padding: 4px; text-align: center; }
  :global(.tc2__slot--filled:hover) { border-color: rgba(255,255,255,0.15); }

  :global(.tc2__slot-img-wrap) { width: 100%; flex: 1; display: flex; align-items: center; justify-content: center; min-height: 0; }
  :global(.tc2__slot-img) { max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4)); }
  :global(.tc2__slot-dot) { width: 24px; height: 24px; border-radius: 50%; }

  :global(.tc2__slot-qty) { position: absolute; top: 3px; left: 3px; font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; color: #fff; background: rgba(0,0,0,0.7); border-radius: 3px; padding: 1px 4px; }
  :global(.tc2__slot-val) { position: absolute; top: 3px; right: 3px; font-family: var(--font-display); font-size: 0.55rem; font-weight: 700; color: #fff; background: rgba(0,0,0,0.7); border-radius: 3px; padding: 1px 4px; }
  :global(.tc2__slot-name) { font-size: 0.55rem; font-weight: 600; color: #fff; line-height: 1.2; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%; padding: 0 2px; }

  /* Remove button (shows on hover) */
  :global(.tc2__slot-rm) { position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; background: rgba(239,68,68,0.85); border: none; border-radius: 3px; color: #fff; cursor: pointer; opacity: 0; transition: opacity 0.15s; z-index: 2; }
  :global(.tc2__slot--filled:hover .tc2__slot-rm) { opacity: 1; }

  /* --- Zone total --- */
  :global(.tc2__zone-total) { display: flex; align-items: center; justify-content: space-between; padding: 0.45rem 0.55rem; background: rgba(0,0,0,0.3); border-left: 2px solid var(--border); border-radius: 0 6px 6px 0; }
  :global(.tc2__zone-total-lbl) { font-size: 0.6rem; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.08em; }
  :global(.tc2__zone-total-num) { font-family: var(--font-display); font-weight: 700; font-size: 1rem; }

  /* --- Center divider --- */
  :global(.tc2__mid) { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; align-self: center; padding: 0 0.15rem; }
  :global(.tc2__vs) { font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; color: var(--text-dim); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-card); }
  :global(.tc2__gauge) { position: relative; width: 2px; height: 100px; background: rgba(255,255,255,0.08); border-radius: 1px; }
  :global(.tc2__gauge-track) { display: none; }
  :global(.tc2__gauge-dot) { position: absolute; left: 50%; transform: translateX(-50%) rotate(45deg); width: 10px; height: 10px; border-radius: 2px; transition: top 0.6s cubic-bezier(0.175,0.885,0.32,1.275); }
  :global(.tc2__swap-btn) { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; color: var(--text-dim); cursor: pointer; transition: border-color 0.2s, color 0.2s; }
  :global(.tc2__swap-btn:hover) { border-color: #a855f7; color: #a855f7; }
  :global(.tc2__swap-btn:disabled) { opacity: 0.4; cursor: not-allowed; }

  @media (max-width: 767px) {
    :global(.tc2__mid) { flex-direction: row; padding: 0.25rem 0; gap: 0.75rem; }
    :global(.tc2__gauge) { width: 60px; height: 2px; }
    :global(.tc2__gauge-dot) { top: 50% !important; left: 50%; transform: translate(-50%, -50%) rotate(45deg); transition: left 0.6s cubic-bezier(0.175,0.885,0.32,1.275); }
  }

  /* --- Verdict card --- */
  :global(.tc2__verdict) { display: flex; align-items: center; gap: 0.85rem; border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
  :global(.tc2__verdict-icon) { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; flex-shrink: 0; }
  :global(.tc2__verdict-body) { flex: 1; min-width: 0; }
  :global(.tc2__verdict-tag) { font-family: var(--font-display); font-size: 1rem; font-weight: 700; }
  :global(.tc2__verdict-msg) { font-size: 0.78rem; color: var(--text-dim); margin-top: 0.1rem; }
  :global(.tc2__verdict-pct) { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; flex-shrink: 0; }

  /* --- Proportion bar --- */
  :global(.tc2__bar-section) { margin-bottom: 1.5rem; }
  :global(.tc2__bar) { display: flex; height: 28px; border-radius: 8px; overflow: hidden; margin-bottom: 0.35rem; }
  :global(.tc2__bar-l) { background: rgba(34,211,238,0.3); display: flex; align-items: center; justify-content: center; min-width: 0; transition: width 0.3s ease; }
  :global(.tc2__bar-r) { background: rgba(129,140,248,0.3); display: flex; align-items: center; justify-content: center; min-width: 0; transition: width 0.3s ease; }
  :global(.tc2__bar-txt) { font-family: var(--font-display); font-size: 0.68rem; font-weight: 700; color: #fff; white-space: nowrap; padding: 0 0.4rem; }
  :global(.tc2__bar-leg) { display: flex; justify-content: space-between; font-size: 0.7rem; font-weight: 600; }

  /* ============================================================
     MODAL: Full-screen item picker
     ============================================================ */

  :global(.tc2__overlay) { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.6); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; padding: 1rem; animation: tc2FadeIn 0.2s ease; }
  :global(.tc2__modal) { width: 95vw; max-width: 640px; max-height: 85vh; background: #141414; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; display: flex; flex-direction: column; overflow: hidden; animation: tc2SlideUp 0.3s cubic-bezier(0.23,1,0.32,1); }

  @keyframes tc2FadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes tc2SlideUp { from { opacity: 0; transform: scale(0.95) translateY(20px); } to { opacity: 1; transform: scale(1) translateY(0); } }

  /* Modal header */
  :global(.tc2__m-head) { display: flex; align-items: center; gap: 0.5rem; padding: 0.85rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
  :global(.tc2__m-title) { flex: 1; font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; color: #fff; }
  :global(.tc2__m-close),
  :global(.tc2__m-back) { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: none; border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; color: var(--text-dim); cursor: pointer; transition: border-color 0.2s, color 0.2s; flex-shrink: 0; }
  :global(.tc2__m-close:hover),
  :global(.tc2__m-back:hover) { border-color: rgba(255,255,255,0.2); color: #fff; }

  /* Search */
  :global(.tc2__m-search) { display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
  :global(.tc2__m-search-icon) { color: var(--text-dim); flex-shrink: 0; }
  :global(.tc2__m-search-input) { flex: 1; background: none; border: none; outline: none; color: #fff; font-family: var(--font-body); font-size: 0.9rem; padding: 0.25rem 0; }
  :global(.tc2__m-search-input::placeholder) { color: var(--text-dim); }

  /* Category tabs */
  :global(.tc2__m-cats) { display: flex; gap: 0.25rem; padding: 0.5rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; overflow-x: auto; }
  :global(.tc2__m-cat) { background: none; border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; padding: 0.3rem 0.65rem; font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--text-dim); cursor: pointer; white-space: nowrap; transition: all 0.15s; }
  :global(.tc2__m-cat:hover) { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.12); }
  :global(.tc2__m-cat--on) { background: rgba(168,85,247,0.12); border-color: rgba(168,85,247,0.3); color: #a855f7; }

  /* Items grid */
  :global(.tc2__m-grid) { flex: 1; overflow-y: auto; overscroll-behavior: contain; padding: 0.65rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.5rem; }
  :global(.tc2__m-item) { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; padding: 0.5rem 0.35rem; border: 1px solid rgba(255,255,255,0.04); border-radius: 8px; cursor: pointer; transition: border-color 0.15s, transform 0.15s; text-align: center; }
  :global(.tc2__m-item:hover) { border-color: rgba(255,255,255,0.15); transform: translateY(-2px); }
  :global(.tc2__m-item-imgbox) { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }
  :global(.tc2__m-item-img) { max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 1px 4px rgba(0,0,0,0.3)); }
  :global(.tc2__m-item-dot) { width: 20px; height: 20px; border-radius: 50%; }
  :global(.tc2__m-item-name) { font-size: 0.65rem; font-weight: 600; color: #fff; line-height: 1.2; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  :global(.tc2__m-item-val) { font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; color: var(--text-dim); }
  :global(.tc2__m-item-val small) { font-weight: 500; opacity: 0.7; }
  :global(.tc2__m-empty) { grid-column: 1 / -1; padding: 2rem; text-align: center; color: var(--text-dim); font-size: 0.85rem; }

  /* --- Configure step --- */
  :global(.tc2__cfg) { padding: 1rem; flex: 1; overflow-y: auto; }
  :global(.tc2__cfg-card) { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem; border-radius: 10px; margin-bottom: 1rem; }
  :global(.tc2__cfg-img) { width: 64px; height: 64px; object-fit: contain; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3)); flex-shrink: 0; }
  :global(.tc2__cfg-info) { display: flex; flex-direction: column; gap: 0.15rem; }
  :global(.tc2__cfg-name) { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: #fff; }
  :global(.tc2__cfg-rarity) { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; }
  :global(.tc2__cfg-base) { font-family: var(--font-display); font-size: 0.82rem; font-weight: 600; color: var(--text-dim); }

  :global(.tc2__cfg-fields) { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem; }
  @media (max-width: 400px) { :global(.tc2__cfg-fields) { grid-template-columns: 1fr; } }

  :global(.tc2__cfg-field) { display: flex; flex-direction: column; gap: 0.2rem; }
  :global(.tc2__cfg-lbl) { font-size: 0.7rem; font-weight: 600; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.04em; }
  :global(.tc2__cfg-input),
  :global(.tc2__cfg-select) { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 0.55rem 0.65rem; color: #fff; font-family: var(--font-body); font-size: 0.85rem; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
  :global(.tc2__cfg-input:focus),
