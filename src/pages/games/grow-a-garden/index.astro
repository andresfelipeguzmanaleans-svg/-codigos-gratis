---
export const prerender = true;
import GameLayout from '../../../layouts/GameLayout.astro';
import GameHero from '../../../components/GameHero.astro';

import valuesData from '../../../data/games/grow-a-garden/values.json';

const total = valuesData.length;
const petCount = valuesData.filter((i: any) => i.category === 'pet').length;
const cropCount = valuesData.filter((i: any) => i.category === 'crop').length;
const divineCount = valuesData.filter((i: any) => i.rarity === 'Divine').length;

const fmt = (n: number) => n.toLocaleString('en-US');

const description = `Complete Grow a Garden value list with ${fmt(total)} items: ${fmt(petCount)} pets and ${fmt(cropCount)} crops. Trade calculator, values, demand levels, and active codes.`;

// Quick links
const quickLinks = [
  { title: 'Value List', desc: `${fmt(total)} items tracked`, href: '/games/grow-a-garden/values/', icon: '💰' },
  { title: 'Trade Calculator', desc: 'Win/Fair/Lose analysis', href: '/games/grow-a-garden/calculator/', icon: '🔢' },
  { title: 'Active Codes', desc: 'Free rewards', href: '/codigos-grow-a-garden/', icon: '🎁' },
];

// Stats
const stats = [
  { label: 'Total Items', value: fmt(total) },
  { label: 'Pets', value: fmt(petCount) },
  { label: 'Crops', value: fmt(cropCount) },
  { label: 'Divine', value: fmt(divineCount) },
];

// FAQ
const faqs = [
  {
    q: 'What is Grow a Garden?',
    a: `Grow a Garden is a popular Roblox game where players grow crops, collect pets, and trade items with other players. With ${fmt(petCount)} pets and ${fmt(cropCount)} crops, there's a huge variety of items to collect and trade.`,
  },
  {
    q: 'How do you trade in Grow a Garden?',
    a: 'To trade in Grow a Garden, approach another player and use the trade menu. You can exchange pets and crops. Always check the value list before trading to ensure a fair deal. Our trade calculator helps you determine if a trade is a Win, Fair, or Lose.',
  },
  {
    q: 'What are the rarest items in Grow a Garden?',
    a: `The rarest items are Divine-tier pets (${fmt(divineCount)} total), followed by Prismatic, Mythical, and Legendary items. Divine pets like Rainbow Elephant and Wind Wyvern hold the highest trade values in the game.`,
  },
  {
    q: 'How do I get Divine pets in Grow a Garden?',
    a: 'Divine pets are extremely rare and are typically obtained through special eggs, events, or trading with other players. Check our value list to see all Divine pets and their current trade values.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Grow a Garden Guide - Codigos Gratis',
  url: new URL('/games/grow-a-garden/', Astro.site).href,
  description,
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title="Grow a Garden Value List & Trade Calculator"
  description={description}
  game="Grow a Garden"
  breadcrumbs={[]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <GameHero title="GROW A GARDEN" subtitle="Pet values, calculator & trading tools" accentColor="#22c55e" />

  <div class="container home-content">
    <!-- QUICK LINKS -->
    <section class="quick-links">
      {quickLinks.map(link => (
        <a href={link.href} class="ql-card">
          <span class="ql-card__icon">{link.icon}</span>
          <div class="ql-card__body">
            <h3 class="ql-card__title">{link.title}</h3>
            <p class="ql-card__desc">{link.desc}</p>
          </div>
          <svg class="ql-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ))}
    </section>

    <!-- STATS -->
    <section class="stats-section">
      <h2 class="section-title">Database</h2>
      <div class="stats-row">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__value">{s.value}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <p class="faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</GameLayout>

<style>
  .home-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
    padding-bottom: 2rem;
  }

  /* Quick links grid */
  .quick-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .quick-links { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .quick-links { grid-template-columns: repeat(3, 1fr); }
  }

  .ql-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .ql-card:hover {
    border-color: rgba(34, 197, 94, 0.3);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .ql-card__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(34, 197, 94, 0.06);
    border-radius: var(--radius);
  }

  .ql-card__body { flex: 1; min-width: 0; }

  .ql-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
  }

  .ql-card__desc {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-top: 1px;
  }

  .ql-card__arrow {
    flex-shrink: 0;
    color: rgba(255,255,255,0.2);
    transition: color 0.2s, transform 0.2s;
  }

  .ql-card:hover .ql-card__arrow {
    color: #22c55e;
    transform: translateX(2px);
  }

  /* Section title */
  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Stats */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    min-width: 72px;
    flex: 1;
  }

  .stat__value {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: #22c55e;
    line-height: 1.2;
  }

  .stat__label {
    font-size: 0.6rem;
    color: var(--text-dim);
    font-weight: 500;
    text-align: center;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(34, 197, 94, 0.2);
  }

  .faq-q {
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: color 0.2s;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.1rem;
    color: var(--text-dim);
    flex-shrink: 0;
    font-weight: 300;
  }

  .faq-item[open] .faq-q::after {
    content: '\2212';
    color: #22c55e;
  }

  .faq-q:hover { color: #22c55e; }

  .faq-a {
    padding: 0 1rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
