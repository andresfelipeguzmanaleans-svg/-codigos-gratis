---
import GameLayout from '../../../../layouts/GameLayout.astro';
import FischHero from '../../../../components/FischHero.astro';

import rawData from '../../../../data/games/fisch/rods.json';
import locationsData from '../../../../data/games/fisch/locations.json';
import { cleanStr } from '../../../../utils/cleanRawData';

// ---------- Types ----------

interface RodData {
  id: string;
  name: string;
  luckBonus: number;
  control: number;
  resilience: number;
  lureSpeed: number;
  obtainMethod: string | null;
  description: string | null;
  howToGet: string | null;
  obtainedFrom: string | null;
  price: string | null;
  stage: number | null;
  wikiLocation: string | null;
  passive: string | null;
  maxWeight: string | null;
  imageUrl: string | null;
}

// ---------- Static paths ----------

export function getStaticPaths() {
  return (rawData as RodData[])
    .filter(i => i.id && i.name)
    .map(item => ({ params: { id: item.id }, props: { item } }));
}

const { item } = Astro.props as { item: RodData };

// Defensive: strip leftover wiki/scraping syntax
item.price = cleanStr(item.price);
item.howToGet = cleanStr(item.howToGet);
item.description = cleanStr(item.description);
item.obtainedFrom = cleanStr(item.obtainedFrom);
item.passive = cleanStr(item.passive);

// ---------- Helpers ----------

function fmtStat(n: number | null): string {
  if (n == null) return '\u2014';
  if (n > 0) return `+${n.toLocaleString('en-US')}`;
  return n.toLocaleString('en-US');
}

function fmtControl(n: number | null): string {
  if (n == null) return '\u2014';
  return n.toFixed(2);
}

const fmt = (n: number) => n.toLocaleString('en-US');

// ---------- Derived data ----------

const isCosmetic =
  (item.luckBonus === 0 || item.luckBonus == null) &&
  (item.control === 0 || item.control == null) &&
  (item.resilience === 0 || item.resilience == null) &&
  (item.lureSpeed === 0 || item.lureSpeed == null);

// Stage colors
const STAGE_COLORS: Record<number, string> = {
  1: '#6b7280', 2: '#3b82f6', 3: '#22c55e', 4: '#f59e0b',
  5: '#ef4444', 6: '#8b5cf6', 7: '#ec4899', 8: '#14b8a6',
  9: '#f97316', 10: '#06b6d4', 11: '#fbbf24', 12: '#e11d48',
};
const stageColor = STAGE_COLORS[item.stage || 0] || '#6b7280';

// Stage → visual theme for image card
const stageTheme: Record<number, string> = {
  1: 'water', 2: 'deep', 3: 'nature', 4: 'flame',
  5: 'inferno', 6: 'mystic', 7: 'cosmic', 8: 'crystal',
  9: 'flame', 10: 'electric', 11: 'divine', 12: 'inferno',
};
const theme = stageTheme[item.stage || 0] || 'water';

// Related rods (same stage, deterministic shuffle by id hash)
const sameStage = (rawData as RodData[])
  .filter(r => r.stage === item.stage && r.id !== item.id && r.id && r.name);
const related = sameStage
  .map(r => ({ r, k: r.id.split('').reduce((a, c) => a + c.charCodeAt(0), 0) }))
  .sort((a, b) => a.k - b.k)
  .map(x => x.r)
  .slice(0, 8);

// Location name → id lookup
const locationIdMap: Record<string, string> = {};
(locationsData as any[]).forEach((l: any) => { if (l.name && l.id) locationIdMap[l.name] = l.id; });
const locationId = item.obtainedFrom ? locationIdMap[item.obtainedFrom] : null;

// Info grid items
const infoItems: { label: string; value: string; icon: string }[] = [];
infoItems.push({ label: 'Luck Bonus', value: fmtStat(item.luckBonus), icon: '\uD83C\uDF40' });
infoItems.push({ label: 'Control', value: fmtControl(item.control), icon: '\uD83C\uDFAF' });
infoItems.push({ label: 'Resilience', value: item.resilience > -1_000_000 ? fmtStat(item.resilience) : '\u221E', icon: '\uD83D\uDEE1\uFE0F' });
infoItems.push({ label: 'Lure Speed', value: fmtStat(item.lureSpeed), icon: '\u26A1' });
if (item.maxWeight) infoItems.push({ label: 'Max Weight', value: `${item.maxWeight} lb`, icon: '\uD83C\uDFCB\uFE0F' });
if (item.price) infoItems.push({ label: 'Price', value: item.price, icon: '\uD83D\uDCB0' });

// Conditions / details
const details: { label: string; value: string; icon: string }[] = [];
if (item.obtainedFrom) details.push({ label: 'Location', value: item.obtainedFrom, icon: '\uD83D\uDCCD' });
if (item.stage) details.push({ label: 'Stage Required', value: `Stage ${item.stage}`, icon: '\u2B50' });
if (item.price) details.push({ label: 'Cost', value: item.price, icon: '\uD83D\uDCB0' });

// Meta description
const metaDesc = `${item.name} is a${item.stage ? ` Stage ${item.stage}` : ''} fishing rod in Fisch. Luck: ${fmtStat(item.luckBonus)}, Control: ${fmtControl(item.control)}, Resilience: ${fmtStat(item.resilience)}, Lure Speed: ${fmtStat(item.lureSpeed)}.${item.obtainedFrom ? ` Obtained from ${item.obtainedFrom}.` : ''}`;

// Schema.org
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${item.name} - Fisch Rod Guide`,
  description: metaDesc,
  author: { '@type': 'Organization', name: 'Codigos Gratis' },
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<GameLayout
  title={`${item.name} - Stats & How to Get | Fisch Roblox`}
  description={metaDesc}
  game="Fisch"
  breadcrumbs={[
    { label: 'Rods', href: '/games/fisch/rods/' },
    { label: item.name, href: `/games/fisch/rods/${item.id}/` },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <!-- HERO -->
  <FischHero
    title={item.name.toUpperCase()}
    subtitle={item.stage ? `Stage ${item.stage} Fishing Rod` : 'Fishing Rod'}
    bgImage={item.imageUrl || '/images/fisch-hero.webp'}
  >
    {item.stage && (
      <span
        class="rd__stage-badge"
        style={`background:${stageColor}20; border-color:${stageColor}; color:${stageColor};`}
      >
        Stage {item.stage}
      </span>
    )}
    <span
      class="rd__type-badge"
      style="background:rgba(255,255,255,0.06); border-color:rgba(255,255,255,0.15); color:var(--text-dim);"
    >
      {isCosmetic ? 'Cosmetic Rod' : 'Fishing Rod'}
    </span>
    {item.price && (
      <div class="rd__giant-price">{item.price}</div>
    )}
  </FischHero>

  <!-- MOBILE: How to Get accordion -->
  {item.howToGet && (
    <div class="container htg-mobile-wrap">
      <details class="htg-accordion htg-accordion--mobile">
        <summary class="htg-accordion__toggle">
          <span class="htg-accordion__icon">\uD83D\uDCD6</span>
          <span class="htg-accordion__text">How to Get</span>
          <svg class="htg-accordion__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 8 10 12 14 8"/></svg>
        </summary>
        <div class="htg-accordion__body">
          {item.howToGet.split('\n\n').map(p => (
            <p class="htg-accordion__para">{p}</p>
          ))}
        </div>
      </details>
    </div>
  )}

  <!-- TWO-COLUMN LAYOUT -->
  <div class="container rd__grid">
    <!-- LEFT: Main content -->
    <div class="rd__main">
      <!-- STATS -->
      <section class="info-section" id="stats">
        <h2 class="section-heading">ROD STATS</h2>
        <div class="info-grid">
          {infoItems.map(item => (
            <div class="info-card">
              <span class="info-card__icon">{item.icon}</span>
              <span class="info-card__label">{item.label}</span>
              <span class="info-card__value">{item.value}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- DETAILS / CONDITIONS -->
      {details.length > 0 && (
        <section class="conditions" id="details">
          <h2 class="section-heading">HOW TO OBTAIN</h2>
          <div class="conditions__list">
            {details.map(c => (
              <div class="cond-row">
                <span class="cond-row__icon">{c.icon}</span>
                <span class="cond-row__label">{c.label}</span>
                {c.label === 'Location' && locationId ? (
                  <span class="cond-row__value">
                    <a href={`/games/fisch/locations/#${locationId}`} class="cond-row__link">{c.value}</a>
                  </span>
                ) : (
                  <span class="cond-row__value">{c.value}</span>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- PASSIVE ABILITY -->
      {item.passive && (
        <section class="passive-section" id="passive">
          <h2 class="section-heading">PASSIVE ABILITY</h2>
          <div class="passive-card">
            <span class="passive-card__icon">\u2728</span>
            <p class="passive-card__text">{item.passive}</p>
          </div>
        </section>
      )}

      <!-- DESCRIPTION / OVERVIEW -->
      {item.description && (
        <section class="overview" id="overview">
          <h2 class="section-heading">OVERVIEW</h2>
          {item.description.split('\n\n').map(p => (
            <p class="overview__text">{p}</p>
          ))}
        </section>
      )}

      <!-- QUICK LINKS -->
      <section class="quick-links">
        <h2 class="section-heading">Explore More</h2>
        <div class="quick-links__grid">
          <a href="/games/fisch/rods/" class="quick-link">
            <span class="quick-link__icon">\uD83C\uDFA3</span>
            <span class="quick-link__text">All Fishing Rods</span>
          </a>
          <a href="/games/fisch/enchantments/" class="quick-link">
            <span class="quick-link__icon">\u2728</span>
            <span class="quick-link__text">Enchantments</span>
          </a>
          <a href="/games/fisch/fish/" class="quick-link">
            <span class="quick-link__icon">\uD83D\uDC1F</span>
            <span class="quick-link__text">Fish Database</span>
          </a>
          <a href="/games/fisch/locations/" class="quick-link">
            <span class="quick-link__icon">\uD83D\uDCCD</span>
            <span class="quick-link__text">All Locations</span>
          </a>
        </div>
      </section>

      <!-- RELATED RODS -->
      {related.length > 0 && (
        <section class="related" id="related">
          <h2 class="section-heading">Other {item.stage ? `Stage ${item.stage}` : ''} Rods</h2>
          <div class="related__grid">
            {related.map(r => (
              <a href={`/games/fisch/rods/${r.id}/`} class="related__card">
                <div class="related__img-wrap">
                  {r.imageUrl ? (
                    <img src={r.imageUrl} alt={r.name} class="related__img" loading="lazy" />
                  ) : (
                    <div class="related__img-placeholder">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity: 0.3; color: var(--text-dim);">
                        <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>
                      </svg>
                    </div>
                  )}
                </div>
                <span class="related__name">{r.name}</span>
                {r.stage && (
                  <span class="related__stage" style={`color: ${STAGE_COLORS[r.stage] || '#6b7280'}`}>Stage {r.stage}</span>
                )}
              </a>
            ))}
          </div>
          <a href="/games/fisch/rods/" class="related__see-all">See all rods &rarr;</a>
        </section>
      )}
    </div>

    <!-- RIGHT: Info sidebar -->
    <aside class="rd__aside">
      <!-- Rod image card -->
      <div class="rd__img-card" data-theme={theme} style={`--r-clr: ${stageColor}`}>
        {item.imageUrl ? (
          <img src={item.imageUrl} alt={item.name} class="rd__img-large" />
        ) : (
          <div class="rd__img-placeholder" style={`background: ${stageColor}20`}>
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style={`opacity: 0.3; color: ${stageColor}`}>
              <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>
            </svg>
          </div>
        )}
      </div>

      <!-- How to Get accordion (desktop sidebar) -->
      {item.howToGet && (
        <details class="htg-accordion htg-accordion--sidebar">
          <summary class="htg-accordion__toggle">
            <span class="htg-accordion__icon">\uD83D\uDCD6</span>
            <span class="htg-accordion__text">How to Get</span>
            <svg class="htg-accordion__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 8 10 12 14 8"/></svg>
          </summary>
          <div class="htg-accordion__body">
            {item.howToGet.split('\n\n').map(p => (
              <p class="htg-accordion__para">{p}</p>
            ))}
          </div>
        </details>
      )}

      <!-- Quick data table -->
      <div class="rd__qd">
        {item.stage && (
          <div class="rd__qd-row">
            <span class="rd__qd-label">Stage</span>
            <span class="rd__qd-value" style={`color: ${stageColor}`}>Stage {item.stage}</span>
          </div>
        )}
        <div class="rd__qd-row">
          <span class="rd__qd-label">Luck</span>
          <span class="rd__qd-value" style="color: #22D3EE">{fmtStat(item.luckBonus)}</span>
        </div>
        <div class="rd__qd-row">
          <span class="rd__qd-label">Control</span>
          <span class="rd__qd-value">{fmtControl(item.control)}</span>
        </div>
        <div class="rd__qd-row">
          <span class="rd__qd-label">Resilience</span>
          <span class="rd__qd-value">{item.resilience > -1_000_000 ? fmtStat(item.resilience) : '\u221E'}</span>
        </div>
        <div class="rd__qd-row">
          <span class="rd__qd-label">Lure Speed</span>
          <span class="rd__qd-value">{fmtStat(item.lureSpeed)}</span>
        </div>
        {item.obtainedFrom && (
          <div class="rd__qd-row">
            <span class="rd__qd-label">Location</span>
            <span class="rd__qd-value">
              {locationId ? (
                <a href={`/games/fisch/locations/#${locationId}`} class="rd__qd-link">{item.obtainedFrom}</a>
              ) : item.obtainedFrom}
            </span>
          </div>
        )}
        {item.price && (
          <div class="rd__qd-row">
            <span class="rd__qd-label">Price</span>
            <span class="rd__qd-value">{item.price}</span>
          </div>
        )}
        {item.maxWeight && (
          <div class="rd__qd-row">
            <span class="rd__qd-label">Max Weight</span>
            <span class="rd__qd-value">{item.maxWeight} lb</span>
          </div>
        )}
      </div>

      <!-- Table of contents -->
      <nav class="rd__toc">
        <span class="rd__toc-title">ON THIS PAGE</span>
        <a href="#stats" class="rd__toc-link">Rod Stats</a>
        {details.length > 0 && <a href="#details" class="rd__toc-link">How to Obtain</a>}
        {item.passive && <a href="#passive" class="rd__toc-link">Passive Ability</a>}
        {item.description && <a href="#overview" class="rd__toc-link">Overview</a>}
        {related.length > 0 && <a href="#related" class="rd__toc-link">Related Rods</a>}
      </nav>
    </aside>
  </div>
</GameLayout>

<style>
  /* ============================================================
     HERO SLOT ELEMENTS
     ============================================================ */

  .rd__stage-badge {
    display: inline-block;
    margin-top: 0.25rem;
    padding: 0.2rem 0.75rem;
    border: 1px solid;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .rd__type-badge {
    display: inline-block;
    margin-top: 0.25rem;
    margin-left: 0.4rem;
    padding: 0.2rem 0.75rem;
    border: 1px solid;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .rd__giant-price {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #22D3EE;
    margin-top: 0.5rem;
    text-shadow: 0 0 40px rgba(34, 211, 238, 0.4);
  }

  /* ============================================================
     TWO-COLUMN GRID LAYOUT
     ============================================================ */

  .rd__grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .rd__grid {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 1.5rem;
      align-items: start;
    }
  }

  .rd__main {
    min-width: 0;
  }

  .rd__aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 767px) {
    .rd__aside {
      order: -1;
    }

    .rd__img-card {
      padding: 1rem;
      background: rgba(15, 29, 53, 0.8);
    }

    .rd__img-large {
      max-height: 160px;
    }

    .rd__toc {
      display: none;
    }
  }

  @media (min-width: 768px) {
    .rd__aside {
      position: sticky;
      top: calc(var(--topbar-h, 56px) + 1rem);
    }
  }

  /* ============================================================
     SECTION HEADINGS
     ============================================================ */

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ============================================================
     STATS INFO GRID
     ============================================================ */

  .info-section {
    margin-bottom: 1.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }

  @media (min-width: 480px) {
    .info-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 768px) {
    .info-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-align: center;
    transition: border-color 0.2s;
  }

  .info-card:hover {
    border-color: rgba(6, 214, 160, 0.2);
  }

  .info-card__icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .info-card__label {
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-card__value {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    word-break: break-word;
  }

  /* ============================================================
     CONDITIONS / DETAILS LIST
     ============================================================ */

  .conditions {
    margin-bottom: 1.5rem;
  }

  .conditions__list {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .cond-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    font-size: 0.88rem;
    border-bottom: 1px solid var(--border);
  }

  .cond-row:last-child {
    border-bottom: none;
  }

  .cond-row__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    width: 1.5rem;
    text-align: center;
  }

  .cond-row__label {
    font-weight: 500;
    color: var(--text-dim);
    min-width: 80px;
    flex-shrink: 0;
  }

  .cond-row__value {
    font-weight: 600;
    color: var(--text);
    flex: 1;
    text-align: right;
  }

  .cond-row__link {
    color: #22d3ee;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }

  .cond-row__link:hover {
    color: #fff;
    text-decoration: underline;
  }

  /* ============================================================
     PASSIVE ABILITY
     ============================================================ */

  .passive-section {
    margin-bottom: 1.5rem;
  }

  .passive-card {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(139, 92, 246, 0.04));
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .passive-card__icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .passive-card__text {
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0;
  }

  /* ============================================================
     OVERVIEW
     ============================================================ */

  .overview {
    margin-bottom: 1.5rem;
  }

  .overview__text {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0;
  }

  .overview__text + .overview__text {
    margin-top: 0.75rem;
  }

  /* ============================================================
     QUICK LINKS
     ============================================================ */

  .quick-links {
    margin-bottom: 1.5rem;
  }

  .quick-links__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.85rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }

  .quick-link:hover {
    border-color: rgba(6, 214, 160, 0.3);
    background: rgba(6, 214, 160, 0.04);
  }

  .quick-link__icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  /* ============================================================
     RELATED RODS
     ============================================================ */

  .related {
    margin-bottom: 1.5rem;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }

  @media (min-width: 480px) {
