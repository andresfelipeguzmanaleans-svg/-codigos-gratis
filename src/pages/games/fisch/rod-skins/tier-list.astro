---
import GameLayout from '../../../../layouts/GameLayout.astro';
import FischHero from '../../../../components/FischHero.astro';
import TierList from '../../../../components/TierList.tsx';
import type { TierItem } from '../../../../components/TierList.tsx';

import rawData from '../../../../data/games/fisch/rod-skins.json';

const items: TierItem[] = (rawData as any[])
  .filter(i => i.name && i.slug)
  .map(i => ({
    name: i.name,
    slug: i.slug,
    tradeValue: i.tradeValue,
    demand: i.demand,
    trend: i.trend,
    rarity: i.rarity,
    imageUrl: i.imageUrl,
  }));

const sources = [...new Set(items.map(i => i.rarity).filter(Boolean) as string[])]
  .sort((a, b) => {
    const count = (s: string) => items.filter(i => i.rarity === s).length;
    return count(b) - count(a);
  });

const total = items.length;
const fmt = (n: number) => n.toLocaleString('en-US');

const pageUrl = new URL('/games/fisch/rod-skins/tier-list/', Astro.site).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Fisch Rod Skins Tier List',
  description: `Tier list ranking all ${fmt(total)} rod skins in Fisch by trade value. SS, S, A, B, C, D tiers.`,
  url: pageUrl,
  numberOfItems: total,
  itemListElement: items
    .sort((a, b) => (b.tradeValue || 0) - (a.tradeValue || 0))
    .slice(0, 20)
    .map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      url: new URL(`/games/fisch/rod-skins/${item.slug}/`, Astro.site).href,
    })),
};
---

<GameLayout
  title={`Rod Skins Tier List - ${fmt(total)} Rod Skins Ranked | Fisch Roblox`}
  description={`Complete Fisch rod skins tier list. All ${fmt(total)} rod skins ranked from SS to D tier by trade value in Enchant Relics. Find the best rod skins to trade.`}
  game="Fisch"
  breadcrumbs={[
    { label: 'Rod Skins', href: '/games/fisch/rod-skins/' },
    { label: 'Tier List', href: '/games/fisch/rod-skins/tier-list/' },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <FischHero title="ROD SKINS TIER LIST" subtitle={`${fmt(total)} rod skins ranked by trade value`} />

  <div class="container">
    <TierList
      client:load
      items={items}
      sources={sources}
      basePath="/games/fisch/rod-skins"
    />
  </div>
</GameLayout>

<style>
  /* ============================================================
     Tier List Styles (shared with boats/tier-list)
     ============================================================ */

  :global(.tl__filters) { display:flex; flex-direction:column; gap:0.6rem; margin-bottom:0.75rem; }
  :global(.tl__search-wrap) { position:relative; }
  :global(.tl__search-ico) { position:absolute; left:0.75rem; top:50%; transform:translateY(-50%); color:var(--text-dim); pointer-events:none; }
  :global(.tl__search) { width:100%; background:var(--bg-card); border:1px solid var(--border); border-radius:10px; padding:0.6rem 0.75rem 0.6rem 2.25rem; color:var(--text); font-family:var(--font-body); font-size:0.9rem; outline:none; transition:border-color 0.2s, box-shadow 0.2s; }
  :global(.tl__search:focus) { border-color:var(--accent); box-shadow:0 0 0 3px rgba(29,162,216,0.15); }
  :global(.tl__search::placeholder) { color:var(--text-dim); }
  :global(.tl__filter-row) { display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center; }
  :global(.tl__src-btn) { background:var(--bg-card); border:1px solid var(--border); border-radius:8px; padding:0.35rem 0.6rem; color:var(--text); font-family:var(--font-body); font-size:0.78rem; cursor:pointer; outline:none; transition:border-color 0.2s, background 0.2s; }
  :global(.tl__src-btn:hover) { border-color:rgba(29,162,216,0.3); }
  :global(.tl__src-btn--on) { border-color:var(--src-color); background:color-mix(in srgb, var(--src-color) 12%, transparent); color:var(--src-color); }
  :global(.tl__clear) { background:none; border:1px solid var(--border); border-radius:8px; padding:0.35rem 0.55rem; color:var(--accent-hot); font-size:0.75rem; cursor:pointer; font-family:var(--font-body); transition:border-color 0.2s; }
  :global(.tl__clear:hover) { border-color:var(--accent-hot); }
  :global(.tl__count) { font-size:0.8rem; color:var(--text-dim); margin-bottom:0.6rem; font-weight:500; }

  :global(.tl__tiers) { display:flex; flex-direction:column; gap:0.5rem; padding-bottom:2rem; }

  :global(.tl__tier) {
    display:grid;
    grid-template-columns:80px 1fr;
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:12px;
    overflow:hidden;
    border-left:3px solid var(--tier-color);
  }
  @media (min-width:640px) {
    :global(.tl__tier) { grid-template-columns:100px 1fr; }
  }

  :global(.tl__tier-label) {
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:0.15rem;
    padding:0.75rem 0.5rem;
    background:var(--tier-bg);
    border-right:1px solid var(--border);
    min-height:80px;
  }
  :global(.tl__tier-id) {
    font-family:var(--font-display);
    font-size:1.75rem;
    font-weight:800;
    color:var(--tier-color);
    line-height:1;
  }
  :global(.tl__tier-desc) {
    font-size:0.6rem;
    font-weight:600;
    color:var(--tier-color);
    text-transform:uppercase;
    letter-spacing:0.5px;
    text-align:center;
    opacity:0.8;
  }
  :global(.tl__tier-count) {
    font-size:0.65rem;
    color:var(--text-dim);
    margin-top:0.1rem;
  }

  :global(.tl__tier-items) {
    display:flex;
    flex-wrap:wrap;
    gap:0.4rem;
    padding:0.6rem;
    align-content:flex-start;
  }

  :global(.tl__item) {
    display:flex;
    flex-direction:column;
    align-items:center;
    width:72px;
    text-decoration:none;
    border-radius:8px;
    padding:0.35rem;
    transition:background 0.15s, transform 0.15s;
  }
  :global(.tl__item:hover) {
    background:rgba(255,255,255,0.05);
    transform:translateY(-1px);
  }
  @media (min-width:640px) {
    :global(.tl__item) { width:82px; }
  }

  :global(.tl__item-img) {
    width:56px;
    height:56px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:rgba(255,255,255,0.03);
    border-radius:8px;
    overflow:hidden;
  }
  :global(.tl__item-img img) {
    max-width:100%;
    max-height:100%;
    object-fit:contain;
  }
  :global(.tl__item-ph) {
    font-size:1.25rem;
    color:var(--text-dim);
  }
  @media (min-width:640px) {
    :global(.tl__item-img) { width:64px; height:64px; }
  }

  :global(.tl__item-info) {
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:0.1rem;
    margin-top:0.25rem;
    width:100%;
  }
  :global(.tl__item-name) {
    font-size:0.65rem;
    font-weight:600;
    color:var(--text);
    text-align:center;
    line-height:1.2;
    overflow:hidden;
    text-overflow:ellipsis;
    display:-webkit-box;
    -webkit-line-clamp:2;
    -webkit-box-orient:vertical;
    width:100%;
  }
  :global(.tl__item-val) {
    font-family:var(--font-mono);
    font-size:0.6rem;
    font-weight:700;
    color:#22D3EE;
  }
  :global(.tl__item-rarity) {
    font-size:0.5rem;
    font-weight:600;
    padding:0.05rem 0.3rem;
    border-radius:9999px;
    border:1px solid var(--badge-color);
    color:var(--badge-color);
    background:color-mix(in srgb, var(--badge-color) 10%, transparent);
  }

  :global(.tl__empty) {
    text-align:center;
    padding:2rem 1rem;
    color:var(--text-dim);
    font-size:0.9rem;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:0.75rem;
  }
</style>
