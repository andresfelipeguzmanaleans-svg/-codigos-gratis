---
export const prerender = true;
import GameLayout from '../../../../layouts/GameLayout.astro';
import FischHero from '../../../../components/FischHero.astro';
import TradingHub from '../../../../components/TradingHub.tsx';

import boatsData from '../../../../data/games/fisch/boats.json';
import rodSkinsData from '../../../../data/games/fisch/rod-skins.json';

// Build item info array for the component
const allItems = [
  ...(boatsData as any[]).map(i => ({
    slug: i.slug,
    name: i.name,
    imageUrl: i.imageUrl,
    tradeValue: i.tradeValue,
    rarity: i.rarity,
    itemType: 'boat',
  })),
  ...(rodSkinsData as any[]).map(i => ({
    slug: i.slug,
    name: i.name,
    imageUrl: i.imageUrl,
    tradeValue: i.tradeValue,
    rarity: i.rarity,
    itemType: 'rod_skin',
  })),
].filter(i => i.slug && i.name);

const total = allItems.length;
const fmt = (n: number) => n.toLocaleString('en-US');

const pageUrl = new URL('/games/fisch/trading/', Astro.site).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Fisch Trading Hub',
  description: `Trade boats, rods, and rare catches with the Fisch community. Browse ${fmt(total)} tradeable items.`,
  url: pageUrl,
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title={`Fisch Trading Hub - Trade Boats & Rod Skins | Fisch Roblox`}
  description={`Trade boats, rods, and rare catches with the Fisch community. Browse active listings, create your own trades, and find the best deals.`}
  game="Fisch"
  breadcrumbs={[{ label: 'Trading Hub', href: '/games/fisch/trading/' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <FischHero title="TRADING HUB" subtitle="Trade boats, rods, and rare catches with the community" />

  <div class="container">
    <TradingHub client:load allItems={allItems} />
  </div>
</GameLayout>

<style>
  /* ============================================================
     Trading Hub Styles
     ============================================================ */

  /* Stats Dashboard */
  :global(.th__stats) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 640px) {
    :global(.th__stats) { grid-template-columns: repeat(4, 1fr); }
  }

  :global(.th__stat) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  :global(.th__stat-label) {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  :global(.th__stat-value) {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.th__stat-value--big) {
    font-size: 1.5rem;
    color: #22D3EE;
  }
  :global(.th__stat-count) {
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  /* Create Listing Button */
  :global(.th__create-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1.25rem;
    background: linear-gradient(135deg, #1DA2D8 0%, #22D3EE 100%);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.2s;
    margin-bottom: 1rem;
  }
  :global(.th__create-btn:hover) {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(29, 162, 216, 0.3);
  }

  /* Filter Tabs */
  :global(.th__filters) {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: 1rem;
  }
  :global(.th__tabs) {
    display: flex;
    gap: 0.35rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4px;
  }
  :global(.th__tab) {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: none;
    border: none;
    border-radius: 8px;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
  }
  :global(.th__tab:hover) { color: var(--text); }
  :global(.th__tab--on) {
    color: #fff;
    background: rgba(29, 162, 216, 0.15);
  }

  /* Filter Row */
  :global(.th__filter-row) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    justify-content: space-between;
  }
  :global(.th__status-filters) {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  :global(.th__filter-btn) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem 0.65rem;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  :global(.th__filter-btn:hover) { border-color: rgba(29, 162, 216, 0.3); color: var(--text); }
  :global(.th__filter-btn--on) {
    border-color: var(--accent);
    background: rgba(29, 162, 216, 0.1);
    color: var(--accent);
  }

  :global(.th__right-filters) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Toggle */
  :global(.th__toggle) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  :global(.th__toggle input) { display: none; }
  :global(.th__toggle-slider) {
    width: 32px;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    position: relative;
    transition: background 0.2s;
  }
  :global(.th__toggle-slider::after) {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.2s;
  }
  :global(.th__toggle input:checked + .th__toggle-slider) { background: var(--accent); }
  :global(.th__toggle input:checked + .th__toggle-slider::after) { transform: translateX(14px); }
  :global(.th__toggle-label) { white-space: nowrap; }

  /* Sort select */
  :global(.th__sort) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem 0.5rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.75rem;
    cursor: pointer;
    outline: none;
  }

  /* Listings */
  :global(.th__listings) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 2rem;
  }

  :global(.th__empty) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 1rem;
    color: var(--text-dim);
    text-align: center;
  }
  :global(.th__empty-title) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }
  :global(.th__empty-desc) {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  :global(.th__spinner) {
    width: 24px;
    height: 24px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: th-spin 0.7s linear infinite;
  }
  @keyframes th-spin {
    to { transform: rotate(360deg); }
  }

  /* Listing Card */
  :global(.th__listing) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  :global(.th__listing:hover) { border-color: rgba(29, 162, 216, 0.25); }

  :global(.th__listing-head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  :global(.th__listing-user) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.th__listing-avatar) {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.05);
  }
  :global(.th__listing-avatar--ph) {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-dim);
  }
  :global(.th__listing-username) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
  }
  :global(.th__listing-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.th__listing-type) {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
  }
  :global(.th__listing-type--offering) {
    color: #22D3EE;
    background: rgba(34, 211, 238, 0.1);
    border: 1px solid rgba(34, 211, 238, 0.2);
  }
  :global(.th__listing-type--wanting) {
    color: #818cf8;
    background: rgba(129, 140, 248, 0.1);
    border: 1px solid rgba(129, 140, 248, 0.2);
  }
  :global(.th__listing-time) {
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  /* Listing Body */
  :global(.th__listing-body) {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    align-items: start;
  }
  :global(.th__listing-side) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  :global(.th__listing-side-label) {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  :global(.th__listing-items) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  :global(.th__listing-item) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  :global(.th__listing-item-img) {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    object-fit: contain;
    background: rgba(255, 255, 255, 0.03);
  }
  :global(.th__listing-item-ph) {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.05);
  }
  :global(.th__listing-item-info) {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
  }
  :global(.th__listing-item-name) {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.th__listing-item-qty) {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }
  :global(.th__listing-total) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: #22D3EE;
    margin-top: 0.15rem;
  }
  :global(.th__listing-none) {
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  :global(.th__listing-arrow) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 1.25rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* Listing Footer */
  :global(.th__listing-foot) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-top: 1px solid var(--border);
  }
  :global(.th__listing-status) {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  :global(.th__listing-status--active) {
    color: #22c55e;
    background: rgba(34, 197, 94, 0.1);
  }
  :global(.th__listing-status--in_progress) {
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.1);
  }
  :global(.th__listing-status--completed) {
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.05);
  }
  :global(.th__listing-status--cancelled) {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }
  :global(.th__listing-offers-tag) {
    font-size: 0.6rem;
    font-weight: 600;
    color: #a855f7;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    padding: 0.1rem 0.45rem;
    border-radius: 9999px;
  }

  /* ============================================================
     Create Listing Modal Styles
     ============================================================ */
  :global(.cl__overlay) {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    backdrop-filter: blur(4px);
  }
  :global(.cl__modal) {
    background: #1a1a1a;
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  :global(.cl__head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  :global(.cl__title) {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
  }
  :global(.cl__close) {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  :global(.cl__close:hover) { color: #fff; background: rgba(255,255,255,0.08); }

  /* Type selector */
  :global(.cl__type-row) {
    display: flex;
    gap: 0.35rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4px;
  }
  :global(.cl__type-btn) {
    flex: 1;
    padding: 0.45rem 0.75rem;
    background: none;
    border: none;
    border-radius: 8px;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
  }
  :global(.cl__type-btn:hover) { color: var(--text); }
  :global(.cl__type-btn--on) {
    color: #fff;
    background: rgba(29, 162, 216, 0.15);
  }

  /* Sides */
  :global(.cl__sides) {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: start;
  }
  @media (max-width: 480px) {
    :global(.cl__sides) { grid-template-columns: 1fr; }
    :global(.cl__arrow) { transform: rotate(90deg); justify-self: center; }
  }
  :global(.cl__side) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  :global(.cl__side-label) {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  :global(.cl__arrow) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 1.5rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* Slots */
  :global(.cl__slots) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }
  :global(.cl__slot) {
    aspect-ratio: 1;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  :global(.cl__slot--empty) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed rgba(255, 255, 255, 0.1);
    cursor: pointer;
    color: rgba(255, 255, 255, 0.2);
    transition: border-color 0.2s, color 0.2s;
  }
  :global(.cl__slot--empty:hover) {
    border-color: rgba(29, 162, 216, 0.4);
    color: rgba(29, 162, 216, 0.6);
  }
  :global(.cl__slot--filled) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.25rem;
    gap: 0.15rem;
  }
  :global(.cl__slot-img) {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }
  :global(.cl__slot-ph) {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
  }
  :global(.cl__slot-name) {
    font-size: 0.55rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    padding: 0 2px;
  }
  :global(.cl__slot-rm) {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    border: none;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s;
  }
  :global(.cl__slot--filled:hover .cl__slot-rm) { opacity: 1; }
  :global(.cl__slot-rm:hover) { color: #ef4444; }

  /* Toggle */
  :global(.cl__toggle) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }
  :global(.cl__toggle input) { display: none; }
  :global(.cl__toggle-slider) {
    width: 36px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    position: relative;
    transition: background 0.2s;
  }
  :global(.cl__toggle-slider::after) {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    background: #fff;
    border-radius: 50%;
    transition: transform 0.2s;
  }
  :global(.cl__toggle input:checked + .cl__toggle-slider) { background: var(--accent); }
  :global(.cl__toggle input:checked + .cl__toggle-slider::after) { transform: translateX(16px); }
  :global(.cl__toggle-text) {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* Error */
  :global(.cl__error) {
    padding: 0.5rem 0.75rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 8px;
    color: #ef4444;
    font-size: 0.8rem;
  }

  /* Submit */
  :global(.cl__submit) {
    width: 100%;
    padding: 0.7rem;
    background: linear-gradient(135deg, #1DA2D8 0%, #22D3EE 100%);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.2s;
  }
  :global(.cl__submit:hover) { transform: translateY(-1px); }
  :global(.cl__submit:disabled) { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Picker Sub-modal */
  :global(.cl__picker-overlay) {
    position: fixed;
    inset: 0;
    z-index: 1001;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  :global(.cl__picker) {
    background: #1a1a1a;
    border: 1px solid var(--border);
    border-radius: 14px;
    width: 100%;
    max-width: 480px;
    max-height: 80vh;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  :global(.cl__picker-head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  :global(.cl__picker-title) {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
  }
  :global(.cl__picker-search) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.45rem 0.65rem;
    color: var(--text-dim);
  }
  :global(.cl__picker-search input) {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
  }
  :global(.cl__picker-cats) {
    display: flex;
    gap: 0.3rem;
  }
  :global(.cl__picker-cat) {
    padding: 0.3rem 0.6rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  :global(.cl__picker-cat:hover) { color: var(--text); }
  :global(.cl__picker-cat--on) {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(29, 162, 216, 0.08);
  }
