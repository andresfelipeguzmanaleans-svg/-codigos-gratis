---
import GameLayout from '../../../../layouts/GameLayout.astro';
import FischHero from '../../../../components/FischHero.astro';
import TradeCalc from '../../../../components/TradeCalc.tsx';
import type { SlimFish, SlimMutation, TradeItem } from '../../../../components/TradeCalc.tsx';

import fishData from '../../../../data/games/fisch/fish.json';
import mutationsData from '../../../../data/games/fisch/mutations.json';
import boatsData from '../../../../data/games/fisch/boats.json';
import rodSkinsData from '../../../../data/games/fisch/rod-skins.json';

// ---------- Slim fish data ----------
const fish: SlimFish[] = (fishData as any[])
  .filter(f => f.id && f.name && f.baseValue != null && f.baseValue > 0)
  .map(f => ({
    id: f.id,
    name: f.name,
    rarity: f.rarity,
    baseValue: f.baseValue,
    baseWeight: f.baseWeight ?? 1,
    weightMin: f.weightRange?.min ?? f.baseWeight ?? 1,
    weightMax: f.weightRange?.max ?? f.baseWeight ?? 1,
  }));

// ---------- Slim mutations data ----------
const mutations: SlimMutation[] = (mutationsData as any[]).map(m => ({
  id: m.id,
  name: m.name,
  multiplier: typeof m.multiplier === 'number' ? m.multiplier : m.multiplier?.max ?? 1,
  category: m.category,
}));

// ---------- Trade items (boats + rod skins) ----------
const tradeItems: TradeItem[] = [
  ...(boatsData as any[]).filter(b => b.slug && b.name && b.tradeValue > 0).map(b => ({
    id: b.slug,
    name: b.name,
    rarity: b.rarity || 'Common',
    value: b.tradeValue,
    imageUrl: b.imageUrl || null,
    itemType: 'boat' as const,
  })),
  ...(rodSkinsData as any[]).filter(r => r.slug && r.name && r.tradeValue > 0).map(r => ({
    id: r.slug,
    name: r.name,
    rarity: r.rarity || 'Common',
    value: r.tradeValue,
    imageUrl: r.imageUrl || null,
    itemType: 'rod_skin' as const,
  })),
];

const fmt = (n: number) => n.toLocaleString('en-US');
const totalItems = fish.length + tradeItems.length;

// Schema.org
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Fisch Trade Calculator',
  description: `Fisch trade calculator for ${totalItems.toLocaleString()} items: fish, boats, and rod skins. Check if your trade is a profit, balanced, or overpay.`,
  url: new URL('/games/fisch/calculator/', Astro.site).href,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title="Trade Calculator - Profit/Balanced/Overpay Checker | Fisch Roblox"
  description={`Check if your Fisch trade is fair. Calculator for ${fmt(fish.length)} fish, ${fmt(tradeItems.filter(t => t.itemType === 'boat').length)} boats, and ${fmt(tradeItems.filter(t => t.itemType === 'rod_skin').length)} rod skins.`}
  game="Fisch"
  breadcrumbs={[{ label: 'Trade Calculator', href: '/games/fisch/calculator/' }]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  </Fragment>

  <FischHero title="TRADE CALCULATOR" subtitle="Analyze exchange protocols" />

  <div class="container">
    <!-- HOW IT WORKS -->
    <section class="tc-explainer">
      <div class="tc-explainer__card">
        <h2 class="tc-explainer__title">HOW IT WORKS</h2>
        <div class="tc-explainer__items">
          <div class="tc-explainer__item">
            <span class="tc-explainer__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
            </span>
            <div>
              <strong>Fish</strong>
              <span class="tc-explainer__desc">Base Value &times; Weight &times; Mutation</span>
            </div>
          </div>
          <div class="tc-explainer__item">
            <span class="tc-explainer__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><polyline points="7 14 11 10 15 13 21 6"/></svg>
            </span>
            <div>
              <strong>Boats &amp; Rod Skins</strong>
              <span class="tc-explainer__desc">ER Value &times; Quantity</span>
            </div>
          </div>
        </div>
        <p class="tc-explainer__text">
          A trade is <strong class="tc-explainer__profit">PROFIT</strong> if you gain &gt;5%,
          <strong class="tc-explainer__balanced">BALANCED</strong> if within &plusmn;5%, or
          <strong class="tc-explainer__overpay">OVERPAY</strong> if you lose &gt;5%.
        </p>
      </div>
    </section>

    <!-- REACT ISLAND -->
    <section class="tc-section">
      <TradeCalc
        client:load
        fish={fish}
        mutations={mutations}
        tradeItems={tradeItems}
      />
    </section>

    <!-- RELATED LINKS -->
    <section class="calc-links">
      <h2 class="calc-links__title">Related Tools & Data</h2>
      <div class="calc-links__grid">
        <a href="/games/fisch/values/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><polyline points="7 14 11 10 15 13 21 6"/></svg>
          </span>
          <strong>Value List</strong>
          <span class="calc-link-card__desc">All trade values and price history</span>
        </a>
        <a href="/games/fisch/boats/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a6 6 0 0 0 12 0"/><path d="M14 20a6 6 0 0 0 12 0"/><path d="M8 4v12"/><path d="M8 4l4 3-4 3"/></svg>
          </span>
          <strong>Boats</strong>
          <span class="calc-link-card__desc">All boats with trade values</span>
        </a>
        <a href="/games/fisch/rod-skins/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><path d="M7 12.5 3 22l7-3 4.5-8"/><path d="M18 2s3 2 3 6-3 6-3 6"/></svg>
          </span>
          <strong>Rod Skins</strong>
          <span class="calc-link-card__desc">All rod skins with trade values</span>
        </a>
        <a href="/games/fisch/fish/" class="calc-link-card">
          <span class="calc-link-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16s9-15 20-4c0 0-9 15-20 4Z"/><circle cx="18" cy="12" r="1"/></svg>
          </span>
          <strong>Fish Database</strong>
          <span class="calc-link-card__desc">Full database with locations and stats</span>
        </a>
      </div>
    </section>
  </div>
</GameLayout>

<style>
  /* ============================================================
     EXPLAINER
     ============================================================ */

  .tc-explainer {
    padding-bottom: 1.5rem;
  }

  .tc-explainer__card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .tc-explainer__title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .tc-explainer__items {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .tc-explainer__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text);
  }

  .tc-explainer__item strong {
    display: block;
    font-size: 0.82rem;
    color: #fff;
  }

  .tc-explainer__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    color: var(--accent);
    flex-shrink: 0;
  }

  .tc-explainer__desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .tc-explainer__text {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .tc-explainer__profit { color: #00ffaa; }
  .tc-explainer__balanced { color: #fbbf24; }
  .tc-explainer__overpay { color: #ff4d4d; }

  .tc-section {
    padding-bottom: 2rem;
  }

  /* ============================================================
     REACT COMPONENT: TradeCalc  (.tc2__*)
     ============================================================ */

  /* --- Root --- */
  :global(.tc2) {
    max-width: 100%;
  }

  /* --- Actions bar --- */
  :global(.tc2__actions) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  :global(.tc2__action-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.85rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  :global(.tc2__action-btn:hover) {
    border-color: var(--accent);
    background: rgba(6, 214, 160, 0.06);
  }

  :global(.tc2__action-btn--danger:hover) {
    border-color: #ff4d4d;
    background: rgba(255, 77, 77, 0.06);
    color: #ff4d4d;
  }

  /* --- Grid layout --- */
  :global(.tc2__grid) {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 767px) {
    :global(.tc2__grid) {
      grid-template-columns: 1fr;
    }
  }

  /* --- VS divider --- */
  :global(.tc2__divider) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    align-self: center;
    padding: 0 0.15rem;
  }

  :global(.tc2__divider-line) {
    width: 2px;
    height: 24px;
    background: var(--border);
    border-radius: 1px;
  }

  :global(.tc2__divider-vs) {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-dim);
  }

  @media (max-width: 767px) {
    :global(.tc2__divider) {
      flex-direction: row;
      padding: 0.25rem 0;
    }

    :global(.tc2__divider-line) {
      width: 32px;
      height: 2px;
    }
  }

  /* --- Side panel --- */
  :global(.tc2__side) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
  }

  :global(.tc2__side-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.65rem;
    margin-bottom: 0.65rem;
    border-bottom: 2px solid var(--border);
  }

  :global(.tc2__side-title) {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  :global(.tc2__side-count) {
    font-size: 0.72rem;
    color: var(--text-dim);
    font-weight: 500;
  }

  :global(.tc2__side-entries) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* --- Entry card --- */
  :global(.tc2__card) {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    padding: 0.7rem;
    transition: border-color 0.2s, background 0.2s;
  }

  :global(.tc2__card:hover) {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.tc2__card-top) {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  :global(.tc2__card-remove) {
    flex-shrink: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  :global(.tc2__card-remove:hover) {
    border-color: #ff4d4d;
    color: #ff4d4d;
    background: rgba(255, 77, 77, 0.08);
  }

  :global(.tc2__card-fields) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  @media (max-width: 479px) {
    :global(.tc2__card-fields) {
      grid-template-columns: 1fr;
    }
  }

  :global(.tc2__card-qty) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.4rem;
    padding: 0.3rem 0;
  }

  :global(.tc2__qty-ctrl) {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  :global(.tc2__qty-btn) {
    background: rgba(255, 255, 255, 0.04);
    border: none;
    width: 30px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  :global(.tc2__qty-btn:hover:not(:disabled)) {
    background: rgba(255, 255, 255, 0.08);
  }

  :global(.tc2__qty-btn:disabled) {
    opacity: 0.3;
    cursor: not-allowed;
  }

  :global(.tc2__qty-val) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0 0.55rem;
    color: var(--text);
  }

  :global(.tc2__card-value) {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.3rem;
    margin-top: 0.4rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  :global(.tc2__card-value-num) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
  }

  :global(.tc2__card-value-unit) {
    font-size: 0.7rem;
    color: var(--text-dim);
    font-weight: 500;
  }

  /* --- Fields --- */
  :global(.tc2__field) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.tc2__field-label) {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  :global(.tc2__field-input),
  :global(.tc2__field-select) {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.4rem 0.55rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  :global(.tc2__field-input:focus),
  :global(.tc2__field-select:focus) {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(6, 214, 160, 0.12);
  }

  :global(.tc2__field-input::placeholder) {
    color: var(--text-dim);
    font-size: 0.75rem;
  }

  :global(.tc2__field-select) {
    cursor: pointer;
    appearance: auto;
  }

  :global(.tc2__field-select option) {
    background: var(--bg-deep);
    color: var(--text);
  }

  /* --- Item picker --- */
  :global(.tc2__picker) {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  :global(.tc2__picker-input) {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.45rem 0.6rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  :global(.tc2__picker-input:focus) {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(6, 214, 160, 0.12);
  }

  :global(.tc2__picker-input::placeholder) {
    color: var(--text-dim);
  }

  :global(.tc2__picker-dropdown) {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    margin-top: 4px;
    background: var(--bg-card);
    border: 1px solid var(--accent);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }

  :global(.tc2__picker-tabs) {
    display: flex;
    border-bottom: 1px solid var(--border);
    padding: 0.25rem;
    gap: 0.15rem;
  }

  :global(.tc2__picker-tab) {
    flex: 1;
    background: none;
    border: none;
    border-radius: 6px;
    padding: 0.3rem 0.35rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-dim);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  :global(.tc2__picker-tab:hover) {
    background: rgba(255, 255, 255, 0.04);
  }

  :global(.tc2__picker-tab--active) {
    background: rgba(6, 214, 160, 0.12);
    color: var(--accent);
  }

  :global(.tc2__picker-list) {
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  :global(.tc2__picker-item) {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.6rem;
    cursor: pointer;
    transition: background 0.1s;
    font-size: 0.8rem;
  }

  :global(.tc2__picker-item:hover) {
    background: rgba(6, 214, 160, 0.08);
  }

  :global(.tc2__picker-img) {
    width: 28px;
    height: 28px;
    object-fit: contain;
    border-radius: 4px;
    flex-shrink: 0;
  }

  :global(.tc2__picker-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  :global(.tc2__picker-name) {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
    font-weight: 500;
  }

  :global(.tc2__picker-meta) {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  :global(.tc2__picker-val) {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-dim);
  }

  :global(.tc2__picker-unit) {
    font-size: 0.6rem;
    color: var(--text-dim);
    opacity: 0.7;
  }

  :global(.tc2__picker-empty) {
    padding: 0.75rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.82rem;
  }

  /* --- Add item button --- */
  :global(.tc2__add-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    width: 100%;
    margin-bottom: 0.5rem;
    background: none;
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 0.45rem;
    color: var(--text-dim);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  :global(.tc2__add-btn:hover) {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* --- Side total --- */
  :global(.tc2__side-total) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.65rem;
    border-top: 2px solid var(--border);
  }

  :global(.tc2__side-total-label) {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  :global(.tc2__side-total-val) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* --- Verdict --- */
  :global(.tc2__verdict) {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  :global(.tc2__verdict-header) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin-bottom: 0.5rem;
  }

  :global(.tc2__verdict-label) {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  :global(.tc2__verdict-badge) {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    padding: 0.2rem 0.75rem;
    border-radius: 6px;
    border: 1px solid;
  }

  :global(.tc2__verdict-msg) {
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
  }

  :global(.tc2__verdict-diff) {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  /* --- Proportion bar --- */
