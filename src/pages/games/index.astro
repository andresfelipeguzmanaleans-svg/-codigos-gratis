---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Game Guides — Fisch, Roblox & More | códigosgratis.com';
const description = 'Explore our in-depth game guides with fish databases, rod stats, mutation info, trade calculators and more.';
---

<Layout title={title} description={description}>
  <Header />
  <main class="main">
    <div class="wrap">
      <nav class="breadcrumbs">
        <a href="/">Inicio</a>
        <svg class="breadcrumbs__sep" width="6" height="10" viewBox="0 0 6 10" fill="none"><path d="M1 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Games</span>
      </nav>

      <h1 class="title">Game Guides</h1>
      <p class="subtitle">In-depth companion guides for your favorite games.</p>

      <div class="grid">
        <a href="/games/fisch/" class="card" style="--card-color: #22D3EE">
          <div class="card__icon" style="background: rgba(34,211,238,0.08); border-color: rgba(34,211,238,0.15)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6-3.56 0-7.56-2.53-8.5-6Z"/><circle cx="2" cy="12" r="1"/>
            </svg>
          </div>
          <div class="card__body">
            <h2 class="card__name" style="color: #22D3EE">Fisch</h2>
            <p class="card__desc">Complete database of 1,200+ fish, rods, mutations, locations and a trade calculator with values.</p>
            <div class="card__tags">
              <span class="tag" style="background:rgba(34,211,238,0.08);color:rgba(34,211,238,0.7);border-color:rgba(34,211,238,0.12)">Fish DB</span>
              <span class="tag" style="background:rgba(34,211,238,0.08);color:rgba(34,211,238,0.7);border-color:rgba(34,211,238,0.12)">Values</span>
              <span class="tag" style="background:rgba(34,211,238,0.08);color:rgba(34,211,238,0.7);border-color:rgba(34,211,238,0.12)">Calculator</span>
              <span class="tag" style="background:rgba(34,211,238,0.08);color:rgba(34,211,238,0.7);border-color:rgba(34,211,238,0.12)">Map</span>
            </div>
          </div>
          <span class="card__arrow">→</span>
        </a>

        <a href="/games/adopt-me/" class="card" style="--card-color: #fbbf24">
          <div class="card__icon" style="background: rgba(251,191,36,0.08); border-color: rgba(251,191,36,0.15)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div class="card__body">
            <h2 class="card__name" style="color: #fbbf24">Adopt Me</h2>
            <p class="card__desc">Value list for 3,289 pets, vehicles, toys, strollers and more with trade calculator.</p>
            <div class="card__tags">
              <span class="tag" style="background:rgba(251,191,36,0.08);color:rgba(251,191,36,0.7);border-color:rgba(251,191,36,0.12)">Values</span>
              <span class="tag" style="background:rgba(251,191,36,0.08);color:rgba(251,191,36,0.7);border-color:rgba(251,191,36,0.12)">Calculator</span>
              <span class="tag" style="background:rgba(251,191,36,0.08);color:rgba(251,191,36,0.7);border-color:rgba(251,191,36,0.12)">3,289 Items</span>
            </div>
          </div>
          <span class="card__arrow">→</span>
        </a>

        <a href="/games/blox-fruits/" class="card" style="--card-color: #a855f7">
          <div class="card__icon" style="background: rgba(168,85,247,0.08); border-color: rgba(168,85,247,0.15)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>
            </svg>
          </div>
          <div class="card__body">
            <h2 class="card__name" style="color: #a855f7">Blox Fruits</h2>
            <p class="card__desc">Complete fruit value list with normal and permanent values, demand and trade calculator.</p>
            <div class="card__tags">
              <span class="tag" style="background:rgba(168,85,247,0.08);color:rgba(168,85,247,0.7);border-color:rgba(168,85,247,0.12)">Values</span>
              <span class="tag" style="background:rgba(168,85,247,0.08);color:rgba(168,85,247,0.7);border-color:rgba(168,85,247,0.12)">Calculator</span>
              <span class="tag" style="background:rgba(168,85,247,0.08);color:rgba(168,85,247,0.7);border-color:rgba(168,85,247,0.12)">Fruits</span>
            </div>
          </div>
          <span class="card__arrow">→</span>
        </a>

        <a href="/games/mm2/" class="card" style="--card-color: #d946a8">
          <div class="card__icon" style="background: rgba(217,70,168,0.08); border-color: rgba(217,70,168,0.15)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d946a8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div class="card__body">
            <h2 class="card__name" style="color: #d946a8">Murder Mystery 2</h2>
            <p class="card__desc">Value list for 913 weapons including Godlies, Chromas, Ancients, Vintages and trade calculator.</p>
            <div class="card__tags">
              <span class="tag" style="background:rgba(217,70,168,0.08);color:rgba(217,70,168,0.7);border-color:rgba(217,70,168,0.12)">Values</span>
              <span class="tag" style="background:rgba(217,70,168,0.08);color:rgba(217,70,168,0.7);border-color:rgba(217,70,168,0.12)">Calculator</span>
              <span class="tag" style="background:rgba(217,70,168,0.08);color:rgba(217,70,168,0.7);border-color:rgba(217,70,168,0.12)">913 Items</span>
            </div>
          </div>
          <span class="card__arrow">→</span>
        </a>

        <a href="/games/grow-a-garden/" class="card" style="--card-color: #22c55e">
          <div class="card__icon" style="background: rgba(34,197,94,0.08); border-color: rgba(34,197,94,0.15)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
            </svg>
          </div>
          <div class="card__body">
            <h2 class="card__name" style="color: #22c55e">Grow a Garden</h2>
            <p class="card__desc">Value list for 612 pets and crops with rarity tiers, demand tracking and trade calculator.</p>
            <div class="card__tags">
              <span class="tag" style="background:rgba(34,197,94,0.08);color:rgba(34,197,94,0.7);border-color:rgba(34,197,94,0.12)">Values</span>
              <span class="tag" style="background:rgba(34,197,94,0.08);color:rgba(34,197,94,0.7);border-color:rgba(34,197,94,0.12)">Calculator</span>
              <span class="tag" style="background:rgba(34,197,94,0.08);color:rgba(34,197,94,0.7);border-color:rgba(34,197,94,0.12)">Pets & Crops</span>
            </div>
          </div>
          <span class="card__arrow">→</span>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .main {
    padding: 2rem 0 4rem;
  }

  .wrap {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  .breadcrumbs a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: var(--accent);
  }

  .breadcrumbs__sep {
    color: var(--text-dim);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .card:hover {
    border-color: color-mix(in srgb, var(--card-color, #22D3EE) 40%, transparent);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--card-color, #22D3EE) 10%, transparent);
    transform: translateY(-2px);
  }

  .card__icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(34, 211, 238, 0.08);
    border-radius: 14px;
    border: 1px solid rgba(34, 211, 238, 0.15);
  }

  .card__body {
    flex: 1;
    min-width: 0;
  }

  .card__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: #22D3EE;
    margin-bottom: 0.35rem;
  }

  .card__desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.5;
    margin-bottom: 0.6rem;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    background: rgba(34, 211, 238, 0.08);
    color: rgba(34, 211, 238, 0.7);
    border: 1px solid rgba(34, 211, 238, 0.12);
    border-radius: 6px;
  }

  .card__arrow {
    font-size: 1.5rem;
    color: var(--text-dim);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }

  .card:hover .card__arrow {
    color: #22D3EE;
    transform: translateX(4px);
  }

  .coming {
    text-align: center;
    color: var(--text-dim);
    font-size: 0.82rem;
    margin-top: 2rem;
    opacity: 0.6;
  }

  @media (max-width: 480px) {
    .card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .card__arrow {
      display: none;
    }
  }
</style>
