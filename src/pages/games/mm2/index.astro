---
export const prerender = true;
import GameLayout from '../../../layouts/GameLayout.astro';
import GameHero from '../../../components/GameHero.astro';

import valuesData from '../../../data/games/mm2/values.json';

const items = valuesData.items;
const total = items.length;
const tradeable = items.filter(i => i.tradeValue > 0).length;
const godlyCount = items.filter(i => i.category === 'Godly').length;
const ancientCount = items.filter(i => i.category === 'Ancient').length;
const chromaCount = items.filter(i => i.category === 'Chroma').length;

const fmt = (n: number) => n.toLocaleString('en-US');

const quickLinks = [
  { title: 'Value List', desc: `${fmt(tradeable)} items with trade values`, href: '/games/mm2/values/', icon: '💰' },
  { title: 'Trade Calculator', desc: 'Win/Fair/Lose analysis', href: '/games/mm2/calculator/', icon: '🔢' },
  { title: 'Active Codes', desc: 'Free rewards & knives', href: '/codigos-murder-mystery-2/', icon: '🎁' },
];

const stats = [
  { label: 'Total Items', value: fmt(total) },
  { label: 'Godly', value: fmt(godlyCount) },
  { label: 'Ancient', value: fmt(ancientCount) },
  { label: 'Chroma', value: fmt(chromaCount) },
];

const faqs = [
  {
    q: 'What is Murder Mystery 2?',
    a: `Murder Mystery 2 (MM2) is a popular Roblox game where players are assigned roles as Innocent, Sheriff, or Murderer. The game features a huge trading economy with ${fmt(total)} collectible weapons (knives, guns, and pets) that players can trade. Godly, Ancient, and Chroma items are the most sought-after.`,
  },
  {
    q: 'How do you trade in MM2?',
    a: 'To trade in MM2, you need to go to the trading server and interact with other players. Before trading, always check item values to ensure you are getting a fair deal. Our value list and trade calculator can help you determine if a trade is a Win, Fair, or Lose.',
  },
  {
    q: 'What are Godly items in MM2?',
    a: `Godly items are among the rarest and most valuable weapons in Murder Mystery 2. There are currently ${fmt(godlyCount)} Godly items in the game. They are extremely difficult to unbox and hold high trade value. Some of the most iconic include Chroma Godlies and limited-edition event Godlies.`,
  },
  {
    q: 'What are Ancient items in MM2?',
    a: `Ancient items are the rarest tier in MM2, even above Godly. There are only ${fmt(ancientCount)} Ancient items in the game. These include legendary weapons like Nik's Scythe and are among the most valuable items you can own.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MM2 Value List & Trade Calculator - Codigos Gratis',
  url: new URL('/games/mm2/', Astro.site).href,
  description: `Complete Murder Mystery 2 database: ${fmt(total)} items with trade values, calculator, and active codes.`,
  publisher: { '@type': 'Organization', name: 'Codigos Gratis' },
};
---

<GameLayout
  title="MM2 Value List & Trade Calculator | Murder Mystery 2"
  description={`Complete MM2 value list and trade calculator with ${fmt(total)} items. Check Godly, Ancient, and Chroma values. Updated daily.`}
  game="MM2"
  breadcrumbs={[]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <GameHero title="MURDER MYSTERY 2" subtitle="Values, calculator & trading tools" accentColor="#d946a8" />

  <div class="container home-content">
    <!-- QUICK LINKS -->
    <section class="quick-links">
      {quickLinks.map(link => (
        <a href={link.href} class="ql-card">
          <span class="ql-card__icon">{link.icon}</span>
          <div class="ql-card__body">
            <h3 class="ql-card__title">{link.title}</h3>
            <p class="ql-card__desc">{link.desc}</p>
          </div>
          <svg class="ql-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ))}
    </section>

    <!-- STATS -->
    <section class="stats-section">
      <h2 class="section-title">Database</h2>
      <div class="stats-row">
        {stats.map(s => (
          <div class="stat">
            <span class="stat__value">{s.value}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <p class="faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</GameLayout>

<style>
  .home-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
    padding-bottom: 2rem;
  }

  /* Quick links grid */
  .quick-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .quick-links { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .quick-links { grid-template-columns: repeat(3, 1fr); }
  }

  .ql-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .ql-card:hover {
    border-color: rgba(217, 70, 168, 0.35);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }

  .ql-card__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(217, 70, 168, 0.08);
    border-radius: var(--radius);
  }

  .ql-card__body { flex: 1; min-width: 0; }

  .ql-card__title {
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    line-height: 1.3;
  }

  .ql-card__desc {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-top: 1px;
  }

  .ql-card__arrow {
    flex-shrink: 0;
    color: rgba(255,255,255,0.2);
    transition: color 0.2s, transform 0.2s;
  }

  .ql-card:hover .ql-card__arrow {
    color: #d946a8;
    transform: translateX(2px);
  }

  /* Section title */
  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Stats */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    min-width: 72px;
    flex: 1;
  }

  .stat__value {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: #d946a8;
    line-height: 1.2;
  }

  .stat__label {
    font-size: 0.6rem;
    color: var(--text-dim);
    font-weight: 500;
    text-align: center;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: rgba(217, 70, 168, 0.25);
  }

  .faq-q {
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: color 0.2s;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.1rem;
    color: var(--text-dim);
    flex-shrink: 0;
    font-weight: 300;
  }

  .faq-item[open] .faq-q::after {
    content: '\2212';
    color: #d946a8;
  }

  .faq-q:hover { color: #d946a8; }

  .faq-a {
    padding: 0 1rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
