---
interface RelatedItem {
  name: string;
  slug: string;
  value: number;
  imageUrl: string | null;
  itemType: string;
}

interface Props {
  items: RelatedItem[];
  currentItemType: 'boat' | 'rod_skin';
}

const { items, currentItemType } = Astro.props;

const DEMAND_COLORS: Record<string, string> = {
  'Very High': '#ef4444', High: '#f59e0b', Medium: '#22c55e', Low: '#3b82f6', 'Very Low': '#6b7280',
};

function fmtValue(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(n % 1000 === 0 ? 0 : 1)}K`;
  return String(n);
}

function itemHref(slug: string, type: string): string {
  const category = type === 'boat' ? 'boats' : 'rod-skins';
  return `/games/fisch/${category}/${slug}/`;
}

const shown = items.slice(0, 6);
---

{shown.length > 0 && (
  <section class="rv">
    <h2 class="rv__heading">Related Values</h2>
    <div class="rv__track">
      {shown.map(item => (
        <a href={itemHref(item.slug, item.itemType || currentItemType)} class="rv__card">
          <div class="rv__img-wrap">
            {item.imageUrl ? (
              <img src={item.imageUrl} alt={item.name} width="72" height="72" loading="lazy" class="rv__img" />
            ) : (
              <div class="rv__img-ph">{item.itemType === 'boat' ? '🚤' : '🎨'}</div>
            )}
          </div>
          <span class="rv__name">{item.name}</span>
          <span class="rv__val">{fmtValue(item.value)} ER</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .rv { margin-top: 1.5rem; }
  .rv__heading {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.75rem;
  }
  .rv__track {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: #334155 transparent;
  }
  .rv__track::-webkit-scrollbar { height: 4px; }
  .rv__track::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }
  .rv__card {
    flex: 0 0 auto;
    width: 110px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.75rem 0.5rem;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 10px;
    text-decoration: none;
    color: #e2e8f0;
    transition: border-color 0.2s, transform 0.2s;
  }
  .rv__card:hover {
    border-color: #22d3ee;
    transform: translateY(-2px);
  }
  .rv__img-wrap {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    background: #0f172a;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rv__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .rv__img-ph {
    font-size: 1.6rem;
  }
  .rv__name {
    font-size: 0.7rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 1.7em;
  }
  .rv__val {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    font-weight: 700;
    color: #22d3ee;
  }

  @media (max-width: 640px) {
    .rv__card { width: 96px; padding: 0.5rem 0.35rem; }
    .rv__img-wrap { width: 48px; height: 48px; }
  }
</style>
